---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Frenchify B1 Intensive Program">
<!-- Header -->
    

    <main>
        <!-- Hero Section -->
        <section class="py-16 md:py-24 bg-gray-50 hero-pattern full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

                <!-- Left Column: Text Content -->
                <div class="text-center lg:text-left">
                    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Frenchify B1 Intensive Program</h1>
                    <p class="text-xl md:text-2xl text-blue-600 font-medium mb-6">Your Foundation for TEF/TCF Canada Success</p>
                    <p class="text-lg text-gray-600 max-w-xl mx-auto lg:mx-0 mb-8">
                        This program is strategically designed to help you build a strong foundation in advanced French concepts and begin focused TEF/TCF Canada preparation — all while keeping the learning flexible, structured, and mentorship-based.
                    </p>
                     <a href="/contact" target="_blank" rel="noopener noreferrer" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 inline-block">
                        Know More
                    </a>
                </div>

                <!-- Right Column: Video Content -->
                <div class="w-full">
                    <div class="rounded-xl shadow-2xl overflow-hidden border border-gray-200">
                        <video
                            src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/68d39928ef40ca3cf4d6ab67.mp4"
                            controls
                            preload="metadata"
                            playsinline
                            poster="" <!-- Recommended: Add a URL to a preview image -->
                            class="w-full h-full"
                        >
                            Your browser does not support the video tag.
                        </video>
                    </div>
                </div>

            </div>
        </section>

        <!-- Goals Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Your B1 Program Goal: Fluency for TEF Canada</h2>
                <ul class="space-y-6">
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Build a Strong Foundation</h3><p class="text-gray-600">Gain fluency for scoring B1/B2 in TEF Canada through targeted training.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Master Advanced Concepts</h3><p class="text-gray-600">Access a complete B1 and B2 grammar syllabus, vocabulary, and structured RSWL training.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Develop Exam-Specific Skills</h3><p class="text-gray-600">Get personalized feedback on speaking and writing to improve fluency, structure, and confidence for the exam.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Enhance Comprehension Strategies</h3><p class="text-gray-600">Learn to filter information and spot keywords with exam-focused listening and reading resources.</p></div></li>
                </ul>
            </div>
        </section>

        <!-- Program Components Section -->
        <section class="py-16 md:py-20 bg-gray-50 full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12">
                     <h2 class="text-3xl font-bold text-gray-900">Program is Divided into 2 Components</h2>
                     <p class="mt-4 text-lg text-gray-600">Combine a self-paced online curriculum with mentorship-based live practice.</p>
                </div>
                <div class="grid lg:grid-cols-2 gap-8 items-stretch">
                    <!-- Live Sessions Card -->
                    <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 flex flex-col">
                        <div class="flex-shrink-0"><i class="fas fa-users text-4xl text-blue-600 mb-4"></i></div>
                        <h3 class="text-2xl font-bold text-gray-800 mb-4">Weekly Live Speaking Sessions</h3>
                        <p class="text-gray-600 mb-6 flex-grow">Get full access to instructor-led sessions to ask questions, clarify B1/B2 grammar, and practice for the TEF exam.</p>
                        <div class="space-y-4">
                            <div>
                                <p class="font-semibold text-gray-700">Speaking Mock Group Sessions (1.5+ hours)</p>
                                <p class="text-gray-600">Tue 8 PM EST, Thu 8 AM EST, Sat 10:30 AM EST, Sun 11:30 AM EST</p>
                            </div>
                            <div>
                                <p class="font-semibold text-gray-700">Practice & Feedback</p>
                                <p class="text-gray-600">Includes speaking prompts, response-building exercises, and personalized TEF/TCF writing analysis.</p>
                            </div>
                        </div>
                    </div>
                    <!-- Online Program Card -->
                    <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 flex flex-col">
                        <div class="flex-shrink-0"><i class="fas fa-laptop-code text-4xl text-blue-600 mb-4"></i></div>
                        <h3 class="text-2xl font-bold text-gray-800 mb-4">Online Course</h3>
                        <p class="text-gray-600 mb-6 flex-grow">Complete the full B1/B2 syllabus at your own pace with a structured program designed for TEF/TCF success.</p>
                        <ul class="space-y-3 text-gray-700">
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Complete B1/B2 Grammar & Vocabulary</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Structured RSWL Training</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Exam-Specific Training for TEF/TCF</li>
                             <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Listening/Reading focused resources</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Key Features Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                     <h2 class="text-3xl font-bold text-gray-900">Key Program Features</h2>
                     <p class="mt-4 text-lg text-gray-600">A flexible, structured, and mentorship-based path to B1.</p>
                </div>

                <div class="relative">
                    <!-- The vertical line -->
                    <div class="absolute left-4 top-0 h-full w-0.5 bg-blue-200" aria-hidden="true"></div>

                    <!-- Timeline items -->
                    <div class="space-y-12">
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-book-open text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Comprehensive Syllabus</h4>
                            <p class="text-gray-600">Access B1 and B2 grammar, vocabulary, and structured training for Reading, Speaking, Writing, and Listening.</p>
                        </div>
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-microphone-alt text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Live Mock Practice</h4>
                            <p class="text-gray-600">Join multiple weekly speaking mock sessions to build fluency, structure, and confidence in an exam-like environment.</p>
                        </div>
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-pen-alt text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Personalized Feedback</h4>
                            <p class="text-gray-600">Receive personalized, exam-specific feedback on your writing (up to 10 submissions) to ensure clarity and confidence.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Access Duration & Final CTA -->
        <section class="py-16 md:py-20 bg-gray-800 text-white full-bleed-section-ghl" id="signup">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <div class="bg-gray-900/50 p-8 rounded-2xl mb-12 border border-gray-700">
                    <div class="flex justify-center items-center gap-4 mb-4">
                        <i class="fas fa-calendar-alt text-3xl text-blue-400"></i>
                        <h3 class="text-2xl font-bold">4-Month Full Access</h3>
                    </div>
                    <p class="text-gray-300">You get 4 months of full access to the online course and all live sessions. This includes up to 10 personalized writing checks to track your improvements over time, with an option to renew.</p>
                </div>

                <h2 class="text-3xl font-bold mb-4">Ready to Focus on TEF/TCF Canada?</h2>
                <p class="text-lg text-gray-300 mb-8">Build an advanced foundation and start your focused exam preparation with expert guidance.</p>
                <a href="/contact" target="_blank" rel="noopener noreferrer" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-10 py-4 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 text-lg">
                    Know More
                </a>
                <p class="text-sm text-gray-400 mt-6">Taught in English. Some content may not be translated.</p>
            </div>
        </section>


<!-- FAQs Section -->
<section class="py-16 md:py-20 full-bleed-section-ghl">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Frequently Asked Questions</h2>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Before Joining</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How do I know if I’m ready to start at B1?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">If you’ve completed A2 or have equivalent skills, you may be ready. Connect with Vyom on WhatsApp at 514-726-5114 to book a quick analysis test and confirm your starting level.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Is the analysis test paid?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Technically, no. There’s a $50 deposit for the test, which is credited toward your fees once you enroll. Based on your results, you’ll be guided to start at either A2 or B1 — and your $50 applies to whichever program you join.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What if I don’t want to start at A2 after the results?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">You can self-study using the feedback and recommendations provided, then rejoin B1 when you feel ready.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Do I need A2 knowledge before joining B1 Intensive?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes. This program is for students who have completed A2 and want to advance quickly toward B1/B2 fluency and TEF/TCF readiness.</p>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Program Details</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What exactly is covered in the program?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Advanced B1 & B2 grammar mastery to strengthen accuracy and expression.<br>Structured RSWL training — Reading, Speaking, Writing, Listening — with practical, exam-aligned exercises.<br>TEF/TCF mock exam practices - specific strategies to improve speed, accuracy, and confidence in each module.<br>Live sessions led by successful TEF/TCF achievers, sharing proven techniques and real exam insights.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How are the live sessions structured?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">There are 4 live sessions in total every week with intense exam preparation and mock training.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Will I get feedback on my writing?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes — you can submit writing tasks for detailed, exam-focused corrections and improvement tips.</p>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Learning Process & Duration</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How long does it take to complete B1 Intensive?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Most students complete it in 3–4 months with consistent participation in live sessions and independent practice.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What makes this program different from learning on my own?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Direct mentorship and real-time feedback from exam experienced trainers.<br>Personalized feedback on speaking and writing tasks to fix mistakes quickly.</p>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Exam Readiness</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How will I know I’m ready for TEF Canada?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">By the end, you’ll be consistently meeting or exceeding exam-level benchmarks in mock tests, with trainer feedback confirming your readiness.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What if I only need CLB 5?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">If your target is CLB 5, you’ll need B1-level skills, plus 1–2 months of B2-style practice to strengthen your exam performance and maximize your score.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What if I can’t commit 4 months to B1?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">No problem at all — connect with Vyom at 514-726-5114, and we’ll create a customized, fast-track plan to fit your timeline without compromising your results.</p>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Promotions or Offers</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Do I get a discount on referring a friend?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes! For every friend you refer, you’ll receive $35 off, and your friend receives $35 off as well!</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Is there a Combo Discount?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Absolutely. We offer special combo pricing when you enroll in multiple programs together. For details, message on WhatsApp at 514-726-5114 directly.</p>
                    </div>
                </div>

            </div>
        </div>

    </div>
</section>
<!-- End of FAQs Section -->
<!-- Testimonial Widget -->
        <section class="py-16 md:py-20 bg-gray-50 full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">What Our Students Say</h2>

                <!-- Reputation Hub Widget Code -->
                
                <iframe class='lc_reviews_widget' src='https://reputationhub.site/reputation/widgets/review_widget/cmjlzerv4DUDyZFj6PYO' frameborder='0' scrolling='no' style='min-width: 100%; width: 100%;'></iframe>
                <!-- End of Widget Code -->

            </div>
        </section>
    </main>

  <style is:global>
/* Styles for FAQ Accordion */
        .faq-answer {
            transition: max-height 0.5s ease-in-out, padding 0.5s ease-in-out;
            max-height: 0;
            overflow: hidden;
            padding-top: 0;
            padding-bottom: 0;
        }

        .faq-answer.open {
            max-height: 500px; /* Adjust based on content length */
            padding-top: 0.5rem;
            padding-bottom: 1rem;
        }

        .faq-toggle .fa-chevron-down {
            transition: transform 0.3s ease-in-out;
        }

        .faq-toggle.open .fa-chevron-down {
            transform: rotate(180deg);
        }
  </style>
</Layout>
