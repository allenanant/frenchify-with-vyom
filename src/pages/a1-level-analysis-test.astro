---
import Layout from '../layouts/Layout.astro';
---

<Layout title="A1 Level Analysis Test - Frenchify with Vyom">
<!-- Header -->
    

    <!-- Hero Section -->
    <section class="pt-20 pb-20 bg-gradient-to-br from-white via-blue-50 to-purple-50 full-bleed-section-ghl">
        <div class="max-w-[1170px] mx-auto px-6">
            <div class="text-center mb-12">
                <div class="inline-flex items-center gap-2 bg-blue-100 text-blue-700 px-4 py-2 rounded-full text-sm font-semibold mb-6">
                    <i class="fas fa-chart-line"></i>
                    OFFICIAL ASSESSMENT
                </div>
                <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6">
                    A1 Level <span class="text-yellow-500">Analysis</span> Test
                </h1>
                <p class="text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
                    Discover exactly where you stand in your French learning journey. Get a comprehensive assessment of your A1 skills and a personalized roadmap to A2 fluency.
                </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
                <a href="https://buy.stripe.com/eVqdR9bnF4Vofjo5Us5sA1b" class="bg-blue-600 text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-blue-700 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 shadow-lg shadow-blue-200">
<i class="fas fa-play-circle mr-2"></i>
                    Start Assessment
</a>
            </div>

            <div class="flex flex-wrap justify-center gap-8 mt-12">
                <div class="flex items-center gap-2 text-gray-600">
                    <i class="fas fa-certificate text-green-600"></i>
                    <span class="font-medium">Certificate</span>
                </div>
                <div class="flex items-center gap-2 text-gray-600">
                    <i class="fas fa-clock text-blue-600"></i>
                    <span class="font-medium">60 mins</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Problem Section -->
    <section class="py-20 bg-gradient-to-br from-red-50 to-pink-50 full-bleed-section-ghl">
        <div class="max-w-[1170px] mx-auto px-6">
            <div class="grid md:grid-cols-2 gap-12 items-center">
                <div class="order-2 md:order-1">
                    <div class="bg-white rounded-2xl p-8 card-shadow border-l-4 border-red-500">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="bg-red-100 p-3 rounded-full">
                                <i class="fas fa-exclamation-triangle text-red-600 text-xl"></i>
                            </div>
                            <h2 class="text-3xl font-bold text-gray-900">Are You Stuck at A1?</h2>
                        </div>
                        <p class="text-lg text-gray-600 leading-relaxed mb-6">
                            Many French learners hit a wall after completing A1. They're unsure if they've truly mastered the fundamentals or if they're ready to move forward.
                        </p>
                        <div class="space-y-4">
                            <div class="flex items-start gap-3">
                                <i class="fas fa-times-circle text-red-500 mt-1"></i>
                                <p class="text-gray-600">Without proper assessment, you risk building on a weak foundation</p>
                            </div>
                            <div class="flex items-start gap-3">
                                <i class="fas fa-times-circle text-red-500 mt-1"></i>
                                <p class="text-gray-600">Leading to confusion, frustration, and wasted time at higher levels</p>
                            </div>
                            <div class="flex items-start gap-3">
                                <i class="fas fa-times-circle text-red-500 mt-1"></i>
                                <p class="text-gray-600">Many students repeat content unnecessarily or skip crucial concepts</p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="order-1 md:order-2">
                    <div class="relative">
                        <div class="absolute -inset-4 bg-gradient-to-r from-red-200 to-pink-200 rounded-full opacity-30 blur-3xl"></div>
                        <img src="https://images.leadconnectorhq.com/image/f_webp/q_80/r_1200/u_https://assets.cdn.filesafe.space/cmjlzerv4DUDyZFj6PYO/media/6808e5afbcc5c4159279e282.jpeg"
                             alt="Confused student"
                             class="relative rounded-2xl shadow-2xl w-full">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works -->
    <section class="py-20 bg-gray-50 full-bleed-section-ghl">
        <div class="max-w-[1170px] mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-4xl font-bold text-gray-900 mb-4">How The Assessment Works</h2>
                <p class="text-xl text-gray-600">Simple & comprehensive</p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <div class="text-center">
                    <div class="relative mb-6">
                        <div class="bg-blue-600 text-white text-2xl font-bold w-16 h-16 rounded-full flex items-center justify-center mx-auto">
                            1
                        </div>
                        <div class="hidden md:block absolute top-8 left-full w-full h-0.5 bg-blue-200"></div>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-900 mb-3">Register & Start</h3>
                    <p class="text-gray-600">Sign up and begin your comprehensive A1 assessment immediately</p>
                </div>

                <div class="text-center">
                    <div class="relative mb-6">
                        <div class="bg-blue-600 text-white text-2xl font-bold w-16 h-16 rounded-full flex items-center justify-center mx-auto">
                            2
                        </div>
                        <div class="hidden md:block absolute top-8 left-full w-full h-0.5 bg-blue-200"></div>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-900 mb-3">Complete Test</h3>
                    <p class="text-gray-600">Take 30-45 minutes to complete all four skill assessments at your own pace</p>
                </div>

                <div class="text-center">
                    <div class="relative mb-6">
                        <div class="bg-blue-600 text-white text-2xl font-bold w-16 h-16 rounded-full flex items-center justify-center mx-auto">
                            3
                        </div>
                    </div>
                    <h3 class="text-xl font-semibold text-gray-900 mb-3">Get Results</h3>
                    <p class="text-gray-600">Receive detailed feedback, scores, and a personalized study plan instantly</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Benefits -->
    <section class="py-20 bg-white full-bleed-section-ghl">
        <div class="max-w-[1170px] mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-4xl font-bold text-gray-900 mb-4">Why Take This Assessment?</h2>
                <p class="text-xl text-gray-600">Transform your French learning journey with clarity and confidence</p>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <div class="flex gap-4">
                    <div class="flex-shrink-0">
                        <div class="bg-blue-100 p-3 rounded-lg">
                            <i class="fas fa-chart-line text-blue-600 text-xl"></i>
                        </div>
                    </div>
                    <div>
                        <h3 class="text-xl font-semibold text-gray-900 mb-2">Track Your Progress</h3>
                        <p class="text-gray-600">Know exactly where you stand and how far you've come in your A1 journey</p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div class="flex-shrink-0">
                        <div class="bg-green-100 p-3 rounded-lg">
                            <i class="fas fa-map-marked-alt text-green-600 text-xl"></i>
                        </div>
                    </div>
                    <div>
                        <h3 class="text-xl font-semibold text-gray-900 mb-2">Personalized Roadmap</h3>
                        <p class="text-gray-600">Get a custom study plan tailored to your strengths and weaknesses</p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div class="flex-shrink-0">
                        <div class="bg-purple-100 p-3 rounded-lg">
                            <i class="fas fa-tachometer-alt text-purple-600 text-xl"></i>
                        </div>
                    </div>
                    <div>
                        <h3 class="text-xl font-semibold text-gray-900 mb-2">Save Time</h3>
                        <p class="text-gray-600">Stop wasting time on content you already know or topics too advanced</p>
                    </div>
                </div>

                <div class="flex gap-4">
                    <div class="flex-shrink-0">
                        <div class="bg-orange-100 p-3 rounded-lg">
                            <i class="fas fa-trophy text-orange-600 text-xl"></i>
                        </div>
                    </div>
                    <div>
                        <h3 class="text-xl font-semibold text-gray-900 mb-2">Build Confidence</h3>
                        <p class="text-gray-600">Move forward with certainty knowing you're ready for A2 level</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="py-20 bg-gradient-to-br from-blue-50 to-purple-50 full-bleed-section-ghl">
        <div class="max-w-[1170px] mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-4xl font-bold text-gray-900 mb-4">Student Success Stories</h2>
                <p class="text-xl text-gray-600">Join hundreds who've accelerated their French journey</p>
            </div>

            <div class="grid md:grid-cols-3 gap-6">
                <div class="bg-white rounded-xl p-6 shadow-lg">
                    <div class="flex gap-1 mb-4 text-yellow-500">
                        ⭐️⭐️⭐️⭐️⭐️
                    </div>
                    <p class="text-gray-600 mb-4">"The grammar test was detailed and well-structured. It took me about an hour to complete, but it was worth it. The questions really made me think and helped me understand how strong my basic grammar is. A great way to check your actual level!"</p>
                    <p class="font-semibold text-gray-900">Ananya Iyer</p>
                </div>

                <div class="bg-white rounded-xl p-6 shadow-lg">
                    <div class="flex gap-1 mb-4 text-yellow-500">
                        ⭐️⭐️⭐️⭐️⭐️
                    </div>
                    <p class="text-gray-600 mb-4">"I found the test quite complete and accurate. Around 80 questions covering all the main grammar topics it gave me a clear idea of where I stand in French and what I should work on next. Perfect for anyone starting their French journey."</p>
                     <p class="font-semibold text-gray-900">Rohit Sharma</p>
                </div>

                <div class="bg-white rounded-xl p-6 shadow-lg">
                    <div class="flex gap-1 mb-4 text-yellow-500">
                        ⭐️⭐️⭐️⭐️⭐️
                    </div>
                    <p class="text-gray-600 mb-4">"This test was exactly what I needed to evaluate my foundation in French grammar. It wasn't too easy or too hard, just the right mix to test every key concept. I felt more confident about my progress after finishing it."</p>
                    <p class="font-semibold text-gray-900">Sneha Patel</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-gradient-to-r from-blue-600 to-purple-600 full-bleed-section-ghl">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="text-4xl font-bold text-white mb-6">Ready to Discover Your True A1 Level?</h2>
            <p class="text-xl text-blue-100 mb-8">Take the assessment now and get your personalized roadmap to French fluency</p>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="https://buy.stripe.com/eVqdR9bnF4Vofjo5Us5sA1b" class="bg-white text-blue-600 px-8 py-4 rounded-full font-semibold text-lg hover:bg-gray-100 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 shadow-lg">
<i class="fas fa-rocket mr-2"></i>
                    Start Assessment Now
</a>
                <a href="https://buy.stripe.com/eVqdR9bnF4Vofjo5Us5sA1b" class="bg-transparent text-white border-2 border-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-white hover:text-blue-600 transition-all duration-300">
<i class="fas fa-calendar mr-2"></i>
                    Schedule for Later
</a>
            </div>

            <div class="mt-8 text-white">
                <p class="text-sm opacity-90">No credit card required • Instant results</p>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-20 bg-gray-50 full-bleed-section-ghl">
        <div class="max-w-4xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-4xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h2>
            </div>

            <div class="space-y-4">
                <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300">
                    <button class="w-full text-left flex justify-between items-center faq-toggle">
                        <h3 class="text-lg font-semibold text-gray-900">Is the assessment really?</h3>
                        <i class="fas fa-chevron-down text-gray-500 transition-transform"></i>
                    </button>
                    <p class="text-gray-600 mt-4 hidden faq-content">No its not as we have limited slots and we do not want you to suffer due to the non-serious candidates. We believe every French learner deserves to know their true level and get proper guidance.</p>
                </div>

                <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300">
                    <button class="w-full text-left flex justify-between items-center faq-toggle">
                        <h3 class="text-lg font-semibold text-gray-900">How long does the assessment take?</h3>
                        <i class="fas fa-chevron-down text-gray-500 transition-transform"></i>
                    </button>
                    <p class="text-gray-600 mt-4 hidden faq-content">The complete assessment takes approximately 30-45 minutes. You can take breaks between sections if needed.</p>
                </div>

                <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300">
                    <button class="w-full text-left flex justify-between items-center faq-toggle">
                        <h3 class="text-lg font-semibold text-gray-900">Do I get a certificate?</h3>
                        <i class="fas fa-chevron-down text-gray-500 transition-transform"></i>
                    </button>
                    <p class="text-gray-600 mt-4 hidden faq-content">Yes! Upon completion, you'll receive a certificate showing your A1 proficiency level that you can share with employers or educational institutions.</p>
                </div>

                <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-lg transition-all duration-300">
                    <button class="w-full text-left flex justify-between items-center faq-toggle">
                        <h3 class="text-lg font-semibold text-gray-900">Can I retake the test?</h3>
                        <i class="fas fa-chevron-down text-gray-500 transition-transform"></i>
                    </button>
                    <p class="text-gray-600 mt-4 hidden faq-content">You can retake the assessment after 30 days to track your progress. This helps ensure you're genuinely improving rather than memorizing answers.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->

  <style is:global>
html {
            overflow-x: hidden;
            width: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            margin: 0;
            padding: 0;
            padding-top: 80px;
            overflow-x: hidden;
            width: 100%;
            min-width: 100%;
        }

        .card-shadow {
            box-shadow: 0 10px 30px -5px rgba(0, 0, 0, 0.1);
        }

        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-20px); }
        }

        .float-animation {
            animation: float 3s ease-in-out infinite;
        }
  </style>
</Layout>
