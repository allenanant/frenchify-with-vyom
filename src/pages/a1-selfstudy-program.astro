---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Frenchify A1 Self-Study Program">
<!-- Header -->
    

    <main>
        <!-- Hero Section -->
        <section class="py-16 md:py-24 bg-gray-50 hero-pattern full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">The Frenchify A1 Self-Study Program</h1>
                <p class="text-xl md:text-2xl text-blue-600 font-medium mb-6">Start Your French Journey — From Zero, At Your Own Pace</p>
                <p class="text-lg text-gray-600 max-w-3xl mx-auto mb-8">
                   If you're a complete beginner, this is exactly where you begin. Our A1 Self-Study Program lays the foundation for everything that follows. It’s structured, strategic, and designed to help you learn independently and confidently.
                </p>
                 <a href="https://link.fastpaydirect.com/payment-link/684971904d2e493514bd28c6" target="_blank" rel="noopener noreferrer" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300">
                    Enroll Now
                </a>
            </div>
        </section>

        <!-- Goals Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Our Goal Is Simple</h2>
                <ul class="space-y-6">
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Understand French Rules</h3><p class="text-gray-600">Help you understand French language rules without confusion.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Learn Common Vocabulary</h3><p class="text-gray-600">Learn the most common vocabulary and phrases used daily.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Form Simple Sentences</h3><p class="text-gray-600">Start forming simple sentences and short paragraphs.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Start Listening</h3><p class="text-gray-600">Begin listening to real conversations and understanding context.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Talk About Yourself</h3><p class="text-gray-600">Talk about yourself, your routine, and daily topics in French.</p></div></li>
                </ul>
            </div>
        </section>

        <!-- Program Components Section -->
        <section class="py-16 md:py-20 bg-gray-50 full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12">
                     <h2 class="text-3xl font-bold text-gray-900">What You Get</h2>
                     <p class="mt-4 text-lg text-gray-600">A comprehensive program designed for independent, confident learning.</p>
                </div>
                <div class="grid lg:grid-cols-2 gap-8 items-stretch">
                    <!-- Online Course Card -->
                    <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 flex flex-col">
                        <div class="flex-shrink-0"><i class="fas fa-laptop-code text-4xl text-blue-600 mb-4"></i></div>
                        <h3 class="text-2xl font-bold text-gray-800 mb-4">Complete Online Course Access</h3>
                        <p class="text-gray-600 mb-6 flex-grow">Perfect for absolute beginners, this course takes you from zero to confident beginner, step-by-step.</p>
                        <ul class="space-y-3 text-gray-700">
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>100% beginner-friendly — no prior French needed</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Covers grammar, vocabulary, reading, listening & writing</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Built-in checkpoints, worksheets, and mini-tests</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Final A1-level test to assess your progress</li>
                        </ul>
                    </div>
                    <!-- All Aspects Card -->
                    <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 flex flex-col">
                        <div class="flex-shrink-0"><i class="fas fa-layer-group text-4xl text-blue-600 mb-4"></i></div>
                        <h3 class="text-2xl font-bold text-gray-800 mb-4">All Aspects Covered for a Strong Foundation</h3>
                        <p class="text-gray-600 mb-6 flex-grow">More than just grammar — this program builds your real-world language skills through every angle.</p>
                        <ul class="space-y-3 text-gray-700">
                           <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Step-by-Step Grammar Lessons</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Pronunciation Basics & Core Vocabulary</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Listening Practice for Common Conversations</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Beginner Speaking & Writing Exercises</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Roadmap Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                     <h2 class="text-3xl font-bold text-gray-900">A Clear Roadmap to Follow</h2>
                     <p class="mt-4 text-lg text-gray-600">Every step is laid out — so you never feel lost, stuck, or confused.</p>
                </div>

                <div class="relative">
                    <!-- The vertical line -->
                    <div class="absolute left-4 top-0 h-full w-0.5 bg-blue-200" aria-hidden="true"></div>

                    <!-- Timeline items -->
                    <div class="space-y-12">
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-play text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Unit 0: Your Starting Plan</h4>
                            <p class="text-gray-600">A guided plan on how to begin learning French effectively.</p>
                        </div>
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-book-open text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Units 1-5: Core A1 Topics & Syllabus</h4>
                            <p class="text-gray-600">Continue through the essentials, covering all necessary A1 skills.</p>
                        </div>
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-graduation-cap text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Unit 6: Revision & Assessment</h4>
                            <p class="text-gray-600">Packed with revision practice and a full A1 test to evaluate your competency.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Access Duration & Final CTA -->
        <section class="py-16 md:py-20 bg-gray-800 text-white full-bleed-section-ghl" id="signup">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <div class="bg-gray-900/50 p-8 rounded-2xl mb-12 border border-gray-700">
                    <div class="flex justify-center items-center gap-4 mb-4">
                        <i class="fas fa-calendar-alt text-3xl text-blue-400"></i>
                        <h3 class="text-2xl font-bold">Instant Access for 4 Months</h3>
                    </div>
                    <p class="text-gray-300">You get 6 full months of access to complete the course at your own pace — whether that’s daily, on weekends, or during spare moments. No short deadlines. No pressure. Just structured, beginner-friendly progress.</p>
                </div>

                <h2 class="text-3xl font-bold mb-4">Start here. Build confidence.</h2>
                <p class="text-lg text-gray-300 mb-8">Lay the foundation for your PR journey. This is where your French story begins — and it starts on your terms.</p>
                <a href="https://link.fastpaydirect.com/payment-link/684971904d2e493514bd28c6" target="_blank" rel="noopener noreferrer" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-10 py-4 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 text-lg">
                    Enroll Now
                </a>
                <p class="text-sm text-gray-400 mt-6">Taught in English. Some content may not be translated.</p>
            </div>
        </section>


<!-- FAQs Section -->
<section class="py-16 md:py-20 full-bleed-section-ghl">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Frequently Asked Questions</h2>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Before Joining</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Do I need to know any French before starting?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <div class="text-gray-600 leading-relaxed pt-2 pb-4">Not at all. The lessons are 100% beginner-friendly, taught in English (with French at higher levels), and guide you through everything from the very basics.</div>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Program Details</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What’s included in the A1 Self-Study Program?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <div class="text-gray-600 leading-relaxed pt-2 pb-4"><ul class='list-disc ml-6 space-y-1'><li >Step-by-step grammar lessons</li><li>Pronunciation basics & core vocabulary</li><li>Listening practice for various conversations</li><li>Beginner speaking & writing exercises</li><li>Built-in checkpoints, worksheets, and mini-tests</li><li>Final A1-level test to assess your progress</li></ul></div>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How long do I get access to the course?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <div class="text-gray-600 leading-relaxed pt-2 pb-4">You get 4 months of access, so you can learn at your own pace — daily, on weekends, or whenever your schedule allows.</div>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Does it really take 4 months to finish?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <div class="text-gray-600 leading-relaxed pt-2 pb-4">No — most students finish in about 5 weeks with 2–3 hours of study per day. The 6-month access simply gives you flexibility and no pressure.</div>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Can I access the course on multiple devices?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <div class="text-gray-600 leading-relaxed pt-2 pb-4">No — you cannot access it on multiple devices as the system flags when this happens.</div>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Learning Process & Duration</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How is the course structured?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <div class="text-gray-600 leading-relaxed pt-2 pb-4">The course follows a clear roadmap:<ul class='list-disc ml-6 mt-2 space-y-1'><li><strong>Unit 0: Starting Plan</strong> — how to begin learning effectively</li><li><strong>Units 1–5: Core A1 topics & syllabus</strong></li><li><strong>Unit 6: Revision & Assessment</strong></li></ul></div>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Is there any speaking practice?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <div class="text-gray-600 leading-relaxed pt-2 pb-4">Yes — you’ll get beginner speaking exercises and listening activities designed to help you start communicating in French.</div>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Exam Readiness</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Does this prepare me for TEF/TCF?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <div class="text-gray-600 leading-relaxed pt-2 pb-4">While it’s focused on A1-level mastery, the program builds the grammar, vocabulary, and listening skills you’ll need for higher-level exam preparation later.</div>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Promotions or Offers</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Do I get a discount on referring a friend?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <div class="text-gray-600 leading-relaxed pt-2 pb-4">Yes! For every friend you refer, you’ll receive $35 off, and your friend receives $35 off as well!</div>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Is there a Combo Discount?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <div class="text-gray-600 leading-relaxed pt-2 pb-4">Absolutely. We offer special combo pricing when you enroll in multiple programs together. For details, message on WhatsApp at 514-726-5114 directly.</div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</section>
<!-- End of FAQs Section -->
<!-- Testimonial Widget -->
        <section class="py-16 md:py-20 bg-gray-50 full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">What Our Students Say</h2>

                <!-- Reputation Hub Widget Code -->
                <script type='text/javascript' src='https://reputationhub.site/reputation/assets/review-widget.js' is:inline></script>
                <iframe class='lc_reviews_widget' src='https://reputationhub.site/reputation/widgets/review_widget/cmjlzerv4DUDyZFj6PYO' frameborder='0' scrolling='no' style='min-width: 100%; width: 100%;'></iframe>
                <!-- End of Widget Code -->

            </div>
        </section>
    </main>

  <style is:global>
/* Styles for FAQ Accordion */
        .faq-answer {
            transition: max-height 0.5s ease-in-out, padding 0.5s ease-in-out;
            max-height: 0;
            overflow: hidden;
            padding-top: 0;
            padding-bottom: 0;
        }

        .faq-answer.open {
            max-height: 500px; /* Adjust based on content length */
            padding-top: 0.5rem;
            padding-bottom: 1rem;
        }

        .faq-toggle .fa-chevron-down {
            transition: transform 0.3s ease-in-out;
        }

        .faq-toggle.open .fa-chevron-down {
            transform: rotate(180deg);
        }
  </style>
</Layout>
