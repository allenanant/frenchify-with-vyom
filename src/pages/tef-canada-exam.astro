---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Frenchify Program for TEF Canada Exam - One-on-One Speaking Sessions">
<!-- Header -->
    

    <!-- Hero Section -->
    <section class="hero-pattern pt-8 pb-10 md:pt-16 md:pb-20 full-bleed-section-ghl">
        <div class="ghl-row mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <div class="inline-block bg-yellow-100 text-yellow-800 font-semibold text-sm px-5 py-2 rounded-full mb-6">
                <i class="fas fa-star mr-2"></i>Exclusive for Frenchify Students Only
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 mb-6">
                <span class="gradient-text">Frenchify Program</span> for TEF Canada Exam
            </h1>
            <p class="text-lg md:text-xl text-gray-600 mb-8 max-w-3xl mx-auto">
                Book one-on-one speaking practice sessions with successful Frenchify students who have cleared their TEF Canada exam and achieved their PR dreams.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="#mentors" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300">
                    <i class="fas fa-users mr-2"></i>View Mentors
                </a>
                <a href="#faqs" class="border-2 border-blue-600 text-blue-600 hover:bg-blue-600 hover:text-white font-semibold px-8 py-3 rounded-lg shadow hover:shadow-md transform hover:-translate-y-1 transition-all duration-300">
                    <i class="fas fa-question-circle mr-2"></i>Read FAQs
                </a>
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section class="py-10 md:py-20 bg-gray-50 full-bleed-section-ghl">
        <div class="ghl-row mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                    How It <span class="gradient-text">Works</span>
                </h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="text-center">
                    <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-user-check text-blue-600 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3">1. Choose a Mentor</h3>
                    <p class="text-gray-600">Browse our TEF-certified mentors, check their CLB scores, and pick the one that fits your learning needs.</p>
                </div>
                <div class="text-center">
                    <div class="bg-purple-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-calendar-check text-purple-600 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3">2. Book a Session</h3>
                    <p class="text-gray-600">Select your preferred session duration and book a convenient time slot directly from the mentor's calendar.</p>
                </div>
                <div class="text-center">
                    <div class="bg-green-100 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-comments text-green-600 text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-3">3. Practice & Improve</h3>
                    <p class="text-gray-600">Join your private one-on-one session, practice speaking with real exam topics, and get personalized feedback.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Mentors Section -->
    <section class="py-10 md:py-20 bg-white full-bleed-section-ghl" id="mentors">
        <div class="ghl-row mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                    Our TEF-Certified <span class="text-blue-600">Mentors</span>
                </h2>
                <p class="text-lg text-gray-600 max-w-3xl mx-auto">
                    Learn from students who have successfully cleared the TEF Canada exam. Each mentor brings real exam experience and proven strategies.
                </p>
            </div>

            <!-- Mentor Cards Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                <!-- Rajan Gurjar -->
                <div class="mentor-card">
                    <div class="p-6 flex flex-col md:flex-row gap-5">
                        <div class="flex flex-col items-start flex-shrink-0">
                            <img src="https://assets.cdn.filesafe.space/cmjlzerv4DUDyZFj6PYO/media/698cc13f5cec6ca7d09cb2b2.png" alt="Rajan Gurjar" class="mentor-avatar">
                            <h3 class="text-xl font-bold text-gray-900 mt-3 text-left">Rajan Gurjar</h3>
                            <p class="text-sm text-green-600 font-medium mt-1"><i class="fas fa-check-circle mr-1"></i>Cleared in 1st Attempt</p>
                        </div>
                        <div class="flex-1">
                            <p class="text-base font-medium text-gray-700 mb-3">TEF Certified</p>
                            <div class="flex flex-wrap gap-2 mb-4">
                                <span class="clb-pill">CLB 9</span>
                                <span class="clb-pill">CLB 11</span>
                                <span class="clb-pill">CLB 8</span>
                                <span class="clb-pill">CLB 7</span>
                            </div>
                            <div class="space-y-2">
                                <a href="https://api.leadconnectorhq.com/widget/bookings/rajan-gurjar-30-mins-one-on-onf25esfyjd43i" target="_blank" class="session-btn">
                                    <span>30 Mins Session</span>
                                    <span>Book Now <i class="fas fa-arrow-right ml-2"></i></span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Darshil Ashawa -->
                <div class="mentor-card">
                    <div class="p-6 flex flex-col md:flex-row gap-5">
                        <div class="flex flex-col items-start flex-shrink-0">
                            <img src="https://assets.cdn.filesafe.space/cmjlzerv4DUDyZFj6PYO/media/698a37fda41b87d3021df22a.png" alt="Darshil Ashawa" class="mentor-avatar">
                            <h3 class="text-xl font-bold text-gray-900 mt-3 text-left">Darshil Ashawa</h3>
                            <p class="text-sm text-green-600 font-medium mt-1"><i class="fas fa-check-circle mr-1"></i>Cleared in 1st Attempt</p>
                        </div>
                        <div class="flex-1">
                            <p class="text-base font-medium text-gray-700 mb-3">TEF Certified</p>
                            <div class="flex flex-wrap gap-2 mb-4">
                                <span class="clb-pill">CLB 9</span>
                                <span class="clb-pill">CLB 9</span>
                                <span class="clb-pill">CLB 7</span>
                                <span class="clb-pill">CLB 8</span>
                            </div>
                            <div class="space-y-2">
                                <a href="https://api.leadconnectorhq.com/widget/bookings/darshil-ashawa-30-mins-one-on-onf25esfyjd43iw2ayyv" target="_blank" class="session-btn">
                                    <span>30 Mins Session</span>
                                    <span>Book Now <i class="fas fa-arrow-right ml-2"></i></span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tapas Rastogi -->
                <div class="mentor-card">
                    <div class="p-6 flex flex-col md:flex-row gap-5">
                        <div class="flex flex-col items-start flex-shrink-0">
                            <img src="https://assets.cdn.filesafe.space/cmjlzerv4DUDyZFj6PYO/media/698b5b8667d7495d2d572eb3.png" alt="Tapas Rastogi" class="mentor-avatar">
                            <h3 class="text-xl font-bold text-gray-900 mt-3 text-left">Tapas Rastogi</h3>
                            <p class="text-sm text-blue-600 font-medium mt-1"><i class="fas fa-certificate mr-1"></i>TEF Mentor</p>
                        </div>
                        <div class="flex-1">
                            <p class="text-base font-medium text-gray-700 mb-3">TEF Certified</p>
                            <div class="flex flex-wrap gap-2 mb-4">
                                <span class="clb-pill">CLB 8</span>
                                <span class="clb-pill">CLB 7</span>
                                <span class="clb-pill">CLB 9</span>
                                <span class="clb-pill">CLB 8</span>
                            </div>
                            <div class="space-y-2">
                                <a href="https://api.leadconnectorhq.com/widget/bookings/tapas-rastogi-30-mins-one-on-onf25esfyjd43id7imab" target="_blank" class="session-btn">
                                    <span>30 Mins Session</span>
                                    <span>Book Now <i class="fas fa-arrow-right ml-2"></i></span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Jay Patel -->
                <div class="mentor-card">
                    <div class="p-6 flex flex-col md:flex-row gap-5">
                        <div class="flex flex-col items-start flex-shrink-0">
                            <img src="https://assets.cdn.filesafe.space/cmjlzerv4DUDyZFj6PYO/media/698a37fd0708e455aec9723a.png" alt="Jay Patel" class="mentor-avatar">
                            <h3 class="text-xl font-bold text-gray-900 mt-3 text-left">Jay Patel</h3>
                            <p class="text-sm text-green-600 font-medium mt-1"><i class="fas fa-check-circle mr-1"></i>Cleared in 2nd Attempt</p>
                        </div>
                        <div class="flex-1">
                            <p class="text-base font-medium text-gray-700 mb-2">TEF Certified</p>
                            <div class="flex flex-wrap gap-2 mb-2">
                                <span class="clb-pill">CLB 8</span>
                                <span class="clb-pill">CLB 7</span>
                                <span class="clb-pill">CLB 7</span>
                                <span class="clb-pill">CLB 8</span>
                            </div>
                            <a href="https://youtu.be/fUiQfeMw3rc?si=xX-Jj6ohN03EHo86" target="_blank" class="inline-flex items-center text-sm text-red-600 hover:text-red-800 font-medium underline mb-3">
                                <i class="fab fa-youtube mr-1"></i>Video
                            </a>
                            <div class="space-y-2">
                                <a href="https://api.leadconnectorhq.com/widget/bookings/jay-patel-30-mins-one-on-onf25esfyjd43id7imabdar3ze" target="_blank" class="session-btn">
                                    <span>30 Mins Session</span>
                                    <span>Book Now <i class="fas fa-arrow-right ml-2"></i></span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Harleen Kaur -->
                <div class="mentor-card">
                    <div class="p-6 flex flex-col md:flex-row gap-5">
                        <div class="flex flex-col items-start flex-shrink-0">
                            <img src="https://assets.cdn.filesafe.space/cmjlzerv4DUDyZFj6PYO/media/698a1fd867d749129b19c343.png" alt="Harleen Kaur" class="mentor-avatar">
                            <h3 class="text-xl font-bold text-gray-900 mt-3 text-left">Harleen Kaur</h3>
                            <p class="text-sm text-blue-600 font-medium mt-1"><i class="fas fa-certificate mr-1"></i>2 years of TEF Teaching</p>
                        </div>
                        <div class="flex-1">
                            <p class="text-base font-medium text-gray-700 mb-2">TEF Certified - 15 Nov, 2024</p>
                            <div class="flex flex-wrap gap-2 mb-3">
                                <span class="clb-pill">CLB 9</span>
                                <span class="clb-pill">CLB 8</span>
                                <span class="clb-pill">CLB 10</span>
                                <span class="clb-pill">CLB 7</span>
                            </div>
                            <a href="https://youtu.be/iNMVm32mUrc?si=BTWkpU882M2ZLPkE" target="_blank" class="inline-flex items-center text-sm text-red-600 hover:text-red-800 font-medium underline mb-3">
                                <i class="fab fa-youtube mr-1"></i>Watch Journey
                            </a>
                            <div class="space-y-2">
                                <a href="https://api.leadconnectorhq.com/widget/bookings/harleen-kaur-30-mins-one-on-onf25esfyjd43id7imab6s2fmx" target="_blank" class="session-btn">
                                    <span>30 Mins Session</span>
                                    <span>Book Now <i class="fas fa-arrow-right ml-2"></i></span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Wafaa Mansuri -->
                <div class="mentor-card">
                    <div class="p-6 flex flex-col md:flex-row gap-5">
                        <div class="flex flex-col items-start flex-shrink-0">
                            <img src="https://assets.cdn.filesafe.space/cmjlzerv4DUDyZFj6PYO/media/69df78f9109243d2ccf97897.png" alt="Wafaa Mansuri" class="mentor-avatar">
                            <h3 class="text-xl font-bold text-gray-900 mt-3 text-left">Wafaa Mansuri</h3>
                            <p class="text-sm text-blue-600 font-medium mt-1"><i class="fas fa-certificate mr-1"></i>Strategic Guidance</p>
                        </div>
                        <div class="flex-1">
                            <p class="text-base font-medium text-gray-700 mb-3">TEF Certified</p>
                            <div class="flex flex-wrap gap-2 mb-4">
                                <span class="clb-pill">CLB 12</span>
                                <span class="clb-pill">CLB 11</span>
                                <span class="clb-pill">CLB 7</span>
                                <span class="clb-pill">CLB 8</span>
                            </div>
                            <div class="space-y-2">
                                <a href="https://api.leadconnectorhq.com/widget/bookings/wafaa-mansuri-30-mins-one-on-onf25esfyjd43id7imab6s2fmxr52418" target="_blank" class="session-btn">
                                    <span>30 Mins Session</span>
                                    <span>Book Now <i class="fas fa-arrow-right ml-2"></i></span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-10 md:py-20 bg-gray-50 full-bleed-section-ghl" id="faqs">
        <div class="mx-auto px-4 sm:px-6 lg:px-8" style="max-width:800px;">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
                    Frequently Asked <span class="gradient-text">Questions</span>
                </h2>
                <p class="text-lg text-gray-600">
                    Everything you need to know about our one-on-one speaking sessions.
                </p>
            </div>

            <div class="space-y-4">
                <!-- FAQ 1 -->
                <div class="faq-item bg-white rounded-xl shadow-md overflow-hidden">
                    <button class="w-full flex items-center justify-between px-6 py-5 text-left" onclick="toggleFaq(this)">
                        <span class="text-lg font-semibold text-gray-900">Is this only for Frenchify students?</span>
                        <i class="fas fa-chevron-down faq-toggle text-blue-600 text-sm"></i>
                    </button>
                    <div class="faq-answer px-6">
                        <p class="text-gray-600 leading-relaxed">Yes. These sessions are exclusively for active Frenchify students. If an outsider books, the session will be canceled without refund.</p>
                    </div>
                </div>

                <!-- FAQ 2 -->
                <div class="faq-item bg-white rounded-xl shadow-md overflow-hidden">
                    <button class="w-full flex items-center justify-between px-6 py-5 text-left" onclick="toggleFaq(this)">
                        <span class="text-lg font-semibold text-gray-900">What happens if I miss my session?</span>
                        <i class="fas fa-chevron-down faq-toggle text-blue-600 text-sm"></i>
                    </button>
                    <div class="faq-answer px-6">
                        <p class="text-gray-600 leading-relaxed">Missed sessions are not refundable. Please be present and on time. They cannot be rebooked.</p>
                    </div>
                </div>

                <!-- FAQ 3 -->
                <div class="faq-item bg-white rounded-xl shadow-md overflow-hidden">
                    <button class="w-full flex items-center justify-between px-6 py-5 text-left" onclick="toggleFaq(this)">
                        <span class="text-lg font-semibold text-gray-900">Can I reschedule my session?</span>
                        <i class="fas fa-chevron-down faq-toggle text-blue-600 text-sm"></i>
                    </button>
                    <div class="faq-answer px-6">
                        <p class="text-gray-600 leading-relaxed">Rescheduling is not available once booked. In special cases, it may be possible with an additional fee.</p>
                    </div>
                </div>

                <!-- FAQ 4 -->
                <div class="faq-item bg-white rounded-xl shadow-md overflow-hidden">
                    <button class="w-full flex items-center justify-between px-6 py-5 text-left" onclick="toggleFaq(this)">
                        <span class="text-lg font-semibold text-gray-900">How do I pay for these sessions?</span>
                        <i class="fas fa-chevron-down faq-toggle text-blue-600 text-sm"></i>
                    </button>
                    <div class="faq-answer px-6">
                        <p class="text-gray-600 leading-relaxed">The best method is credit card payment through the booking page. You may also pay via e-transfer to frenchifyfee@gmail.com. If you have a Coupon Code you may use that.</p>
                    </div>
                </div>

                <!-- FAQ 5 -->
                <div class="faq-item bg-white rounded-xl shadow-md overflow-hidden">
                    <button class="w-full flex items-center justify-between px-6 py-5 text-left" onclick="toggleFaq(this)">
                        <span class="text-lg font-semibold text-gray-900">Can I book the same time slot every week?</span>
                        <i class="fas fa-chevron-down faq-toggle text-blue-600 text-sm"></i>
                    </button>
                    <div class="faq-answer px-6">
                        <p class="text-gray-600 leading-relaxed">Time slots cannot be guaranteed. Availability changes weekly, so we recommend booking in advance.</p>
                    </div>
                </div>

                <!-- FAQ 6 -->
                <div class="faq-item bg-white rounded-xl shadow-md overflow-hidden">
                    <button class="w-full flex items-center justify-between px-6 py-5 text-left" onclick="toggleFaq(this)">
                        <span class="text-lg font-semibold text-gray-900">Can I book multiple sessions in advance?</span>
                        <i class="fas fa-chevron-down faq-toggle text-blue-600 text-sm"></i>
                    </button>
                    <div class="faq-answer px-6">
                        <p class="text-gray-600 leading-relaxed">Yes. You may book multiple sessions ahead of time to ensure availability.</p>
                    </div>
                </div>

                <!-- FAQ 7 -->
                <div class="faq-item bg-white rounded-xl shadow-md overflow-hidden">
                    <button class="w-full flex items-center justify-between px-6 py-5 text-left" onclick="toggleFaq(this)">
                        <span class="text-lg font-semibold text-gray-900">Are these sessions private or group sessions?</span>
                        <i class="fas fa-chevron-down faq-toggle text-blue-600 text-sm"></i>
                    </button>
                    <div class="faq-answer px-6">
                        <p class="text-gray-600 leading-relaxed">These are fully one-on-one private speaking sessions (not group classes).</p>
                    </div>
                </div>

                <!-- FAQ 8 -->
                <div class="faq-item bg-white rounded-xl shadow-md overflow-hidden">
                    <button class="w-full flex items-center justify-between px-6 py-5 text-left" onclick="toggleFaq(this)">
                        <span class="text-lg font-semibold text-gray-900">Will I receive a recording of the session?</span>
                        <i class="fas fa-chevron-down faq-toggle text-blue-600 text-sm"></i>
                    </button>
                    <div class="faq-answer px-6">
                        <p class="text-gray-600 leading-relaxed">No. Frenchify does not provide recordings. You may record the session on your own device.</p>
                    </div>
                </div>

                <!-- FAQ 9 -->
                <div class="faq-item bg-white rounded-xl shadow-md overflow-hidden">
                    <button class="w-full flex items-center justify-between px-6 py-5 text-left" onclick="toggleFaq(this)">
                        <span class="text-lg font-semibold text-gray-900">What should I prepare before joining?</span>
                        <i class="fas fa-chevron-down faq-toggle text-blue-600 text-sm"></i>
                    </button>
                    <div class="faq-answer px-6">
                        <p class="text-gray-600 leading-relaxed">Come with one speaking topic ready, or be prepared to do an on-the-spot topic for practice.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->

  <style is:global>
.mentor-card {
            transition: all 0.3s ease;
            background: white;
            border-radius: 16px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
            overflow: hidden;
        }

        .mentor-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        }

        .mentor-avatar {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            object-fit: cover;
            border: none;
            flex-shrink: 0;
        }

        .avatar-placeholder {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            font-weight: 700;
            color: white;
            flex-shrink: 0;
        }

        .clb-pill {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 9999px;
            font-size: 12px;
            font-weight: 600;
            color: #374151;
            background: #f3f4f6;
        }

        .session-btn {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #2563eb;
            color: white;
            font-weight: 500;
            padding: 12px 16px;
            border-radius: 12px;
            transition: all 0.3s ease;
            text-decoration: none;
            font-size: 15px;
            box-shadow: 0 2px 8px rgba(37, 99, 235, 0.25);
        }

        .session-btn:hover {
            background: #1d4ed8;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(37, 99, 235, 0.35);
        }

        .session-btn .price {
            font-weight: 700;
        }

        .faq-item {
            transition: all 0.3s ease;
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease, padding 0.3s ease;
            padding-top: 0;
            padding-bottom: 0;
        }

        .faq-answer.open {
            max-height: 300px;
            padding-top: 4px;
            padding-bottom: 20px;
        }

        .faq-toggle {
            transition: transform 0.3s ease;
        }

        .faq-toggle.open {
            transform: rotate(180deg);
        }

        .card-content {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
  </style>
</Layout>
