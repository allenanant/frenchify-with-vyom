---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Frenchify A1 Intensive Program">
<!-- Header -->
    

    <main>
        <!-- Hero Section -->
        <section class="py-16 md:py-24 bg-gray-50 hero-pattern full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

                <!-- Left Column: Text Content -->
                <div class="text-center lg:text-left">
                    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Frenchify A1 Intensive Program</h1>
                    <p class="text-xl md:text-2xl text-blue-600 font-medium mb-6">Start Your French Journey — From Zero to Confident Beginner</p>
                    <p class="text-lg text-gray-600 max-w-xl mx-auto lg:mx-0 mb-8">
                        If you're a complete beginner, this is exactly where you begin. Our A1 Program lays the foundation for everything that follows. It’s structured, strategic, and designed to help you learn efficiently.
                    </p>
                     <a href="https://link.fastpaydirect.com/payment-link/67e8ba24717876a0a6a43b45" target="_blank" rel="noopener noreferrer" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 inline-block">
                        Get Started Now
                    </a>
                </div>

                <!-- Right Column: Video Content -->
                <div class="w-full">
                    <div class="rounded-xl shadow-2xl overflow-hidden border border-gray-200">
                        <video
                            src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/68d39928e1ce452bf0f67453.mp4"
                            controls
                            preload="metadata"
                            playsinline
                            poster="" <!-- Recommended: Add a URL to a preview image -->
                            class="w-full h-full"
                        >
                            Your browser does not support the video tag.
                        </video>
                    </div>
                </div>

            </div>
        </section>

        <!-- Goals Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">What You Will Achieve</h2>
                <ul class="space-y-6">
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Master the Fundamentals</h3><p class="text-gray-600">Understand core French grammar rules and pronunciation without confusion.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Build Practical Vocabulary</h3><p class="text-gray-600">Learn the most common words and phrases used in daily conversations.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Start Communicating</h3><p class="text-gray-600">Form simple sentences, ask questions, and talk about yourself and your routine.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Develop Listening Skills</h3><p class="text-gray-600">Begin to understand real, spoken French in common situations.</p></div></li>
                </ul>
            </div>
        </section>

        <!-- Program Components Section -->
        <section class="py-16 md:py-20 bg-gray-50 full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12">
                     <h2 class="text-3xl font-bold text-gray-900">Two Powerful Learning Components</h2>
                     <p class="mt-4 text-lg text-gray-600">Get the best of both worlds: flexible self-study and expert-led live interaction.</p>
                </div>
                <div class="grid lg:grid-cols-2 gap-8 items-stretch">
                    <!-- Live Sessions Card -->
                    <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 flex flex-col">
                        <div class="flex-shrink-0"><i class="fas fa-users text-4xl text-blue-600 mb-4"></i></div>
                        <h3 class="text-2xl font-bold text-gray-800 mb-4">Live Interactive Sessions</h3>
                        <p class="text-gray-600 mb-6 flex-grow">Reinforce your learning, ask questions, and practice with instructors and peers in four dedicated sessions each week.</p>
                        <div>
                            <p class="font-semibold text-gray-700">Doubt Sessions (3x weekly)</p>
                            <p class="text-gray-600 mb-3">Monday 8 PM EST, Thursday 7 PM EST, Sunday 10 AM EST</p>
                            <p class="font-semibold text-gray-700">Activity Session (1x weekly)</p>
                            <p class="text-gray-600">Sat 8 AM EST</p>
                        </div>
                    </div>
                    <!-- Online Program Card -->
                    <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 flex flex-col">
                        <div class="flex-shrink-0"><i class="fas fa-laptop-code text-4xl text-blue-600 mb-4"></i></div>
                        <h3 class="text-2xl font-bold text-gray-800 mb-4">Complete Online Program</h3>
                        <p class="text-gray-600 mb-6 flex-grow">Access a comprehensive, step-by-step curriculum anytime. Perfect for absolute beginners, covering all A1 skills from zero.</p>
                        <ul class="space-y-3 text-gray-700">
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>100% beginner-friendly lessons</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>All skills covered: Reading, Writing, Listening & Speaking</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Built-in worksheets, quizzes, and a final A1 test</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Roadmap Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                     <h2 class="text-3xl font-bold text-gray-900">Your Step-by-Step Learning Roadmap</h2>
                     <p class="mt-4 text-lg text-gray-600">We've laid out every step, so you never feel lost, stuck, or confused.</p>
                </div>

                <div class="relative">
                    <!-- The vertical line -->
                    <div class="absolute left-4 top-0 h-full w-0.5 bg-blue-200" aria-hidden="true"></div>

                    <!-- Timeline items -->
                    <div class="space-y-12">
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-play text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Unit 0: Your Starting Plan</h4>
                            <p class="text-gray-600">A guided plan on how to begin learning French effectively and make the most of the course.</p>
                        </div>
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-book-open text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Units 1-5: Core A1 Syllabus</h4>
                            <p class="text-gray-600">Dive into the essentials, covering all necessary grammar, vocabulary, and conversational topics for the A1 level.</p>
                        </div>
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-graduation-cap text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Unit 6: Revision & Assessment</h4>
                            <p class="text-gray-600">Consolidate your knowledge with revision practice and a full A1-level test to evaluate your competency.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Access Duration & Final CTA (More Condensed) -->
        <section class="py-10 md:py-12 bg-gray-800 text-white full-bleed-section-ghl" id="signup">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <div class="bg-gray-900/50 p-6 rounded-2xl mb-6 border border-gray-700">
                    <div class="flex justify-center items-center gap-4 mb-3">
                        <i class="fas fa-calendar-alt text-3xl text-blue-400"></i>
                        <h3 class="text-2xl font-bold">4-Month Full Access</h3>
                    </div>
                    <p class="text-gray-300">You get 4 full months of access to the online course and all live sessions. While the average student completes the A1 program in about 5 weeks, the extended access gives you total flexibility to learn at your own pace without pressure.</p>
                </div>

                <h2 class="text-3xl font-bold mb-3">Ready to Start Your French Story?</h2>
                <p class="text-lg text-gray-300 mb-5">Build your confidence and lay the perfect foundation for your fluency journey.</p>
                <a href="https://link.fastpaydirect.com/payment-link/67e8ba24717876a0a6a43b45" target="_blank" rel="noopener noreferrer" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-10 py-3 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 text-lg">
                    Sign Up Now
                </a>
                <p class="text-sm text-gray-400 mt-4">Taught in English. Some content may not be translated.</p>
            </div>
        </section>

        <!-- FAQ Section (Moved Up) -->
        <section class="py-16 md:py-20 bg-white full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-16">Frequently Asked Questions</h2>
                <div class="space-y-12">

                    <!-- Before Joining -->
                    <div>
                        <h3 class="text-2xl font-semibold text-gray-800 mb-6 pb-2 border-b-2 border-blue-100">Before Joining</h3>
                        <div class="space-y-4">
                            <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">Do I need any French knowledge before joining A1 Intensive?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">No — this program is designed for complete beginners starting from zero. We guide you through every step so you can start speaking, understanding, and reading French with confidence.</p>
                            </details>
                        </div>
                    </div>

                    <!-- Program Details -->
                    <div>
                        <h3 class="text-2xl font-semibold text-gray-800 mb-6 pb-2 border-b-2 border-blue-100">Program Details</h3>
                        <div class="space-y-4">
                            <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">What’s included in A1 Intensive?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">You get 4 live sessions per week (3 doubt-clearing + 1 activity), a complete step-by-step online course, built-in quizzes and worksheets, vocabulary lists, pronunciation guides, speaking assignments, and a final A1 test to measure your progress.</p>
                            </details>
                             <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">What happens if I miss a live class?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">You’ll get the class recording directly within the community group before your next session.</p>
                            </details>
                             <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">Is there a community group for A1 Intensive students?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">Yes — you’ll be part of an active learning community for daily practice, peer feedback, and extra support between classes.</p>
                            </details>
                        </div>
                    </div>

                    <!-- Learning Process & Duration -->
                    <div>
                        <h3 class="text-2xl font-semibold text-gray-800 mb-6 pb-2 border-b-2 border-blue-100">Learning Process & Duration</h3>
                        <div class="space-y-4">
                            <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">How long will it take to complete A1 Intensive?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">It takes about 5 weeks for a beginner to complete A1 with 2–3 hours of daily study. You’ll still have 4 months of total course access for flexibility.</p>
                            </details>
                             <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">Does it take 4 months for A1?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">No — that’s the course access timeline. The actual study time is about 5 weeks on average for most beginners.</p>
                            </details>
                             <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">How is progress tracked in A1 Intensive?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">Progress is tracked by unit completion and during live session discussions where your understanding is checked regularly.</p>
                            </details>
                        </div>
                    </div>

                    <!-- Exam Readiness -->
                    <div>
                        <h3 class="text-2xl font-semibold text-gray-800 mb-6 pb-2 border-b-2 border-blue-100">Exam Readiness</h3>
                        <div class="space-y-4">
                            <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">Does A1 Intensive prepare me for TEF/TCF?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">While the main goal is to master A1, we include early TEF-style exercises so your exam preparation begins naturally.</p>
                            </details>
                             <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">Are all assignments mandatory?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">Yes — they’re designed to help you master listening, speaking, reading, and writing so you move to A2 with confidence.</p>
                            </details>
                             <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">What’s included in the A1 test?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">A complete grammar evaluation with feedback and personalised improvement tips.</p>
                            </details>
                        </div>
                    </div>

                    <!-- Promotions or Offers -->
                    <div>
                        <h3 class="text-2xl font-semibold text-gray-800 mb-6 pb-2 border-b-2 border-blue-100">Promotions or Offers</h3>
                        <div class="space-y-4">
                            <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">Do I get a discount on referring a friend?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">Yes! For every friend you refer, you’ll receive $35 off!</p>
                            </details>
                             <details class="group border-b border-gray-200 pb-4">
                                <summary class="flex justify-between items-center cursor-pointer list-none">
                                    <span class="font-medium text-lg text-gray-800 group-hover:text-blue-600">Is there a Combo Discount?</span>
                                    <span class="text-blue-600 transition-transform duration-300 group-open:rotate-180">
                                        <i class="fas fa-chevron-down"></i>
                                    </span>
                                </summary>
                                <p class="mt-4 text-gray-600">Absolutely. We offer special combo pricing when you enroll in multiple programs together. For details, message on WhatsApp at 514-726-5114 directly.</p>
                            </details>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- Testimonial Widget -->
        <section class="py-16 md:py-20 bg-gray-50 full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">What Our Students Say</h2>

                <!-- Reputation Hub Widget Code -->
                
                <iframe class='lc_reviews_widget' src='https://reputationhub.site/reputation/widgets/review_widget/cmjlzerv4DUDyZFj6PYO' frameborder='0' scrolling='no' style='min-width: 100%; width: 100%;'></iframe>
                <!-- End of Widget Code -->

            </div>
        </section>
    </main>
</Layout>
