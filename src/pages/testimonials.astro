---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Testimonials - Frenchify">
<!-- Header -->
    

    <main>
        <!-- Hero Section -->
        <section class="py-16 md:py-20 bg-white full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">What Our Students Are Saying</h1>
                <p class="text-lg text-gray-600 max-w-3xl mx-auto">
                    Real stories and results from learners who transformed their French skills with Frenchify.
                </p>
            </div>
        </section>

        <!-- Review Widget Section -->
        <section class="py-16 md:py-20">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Our Reviews on Trustpilot</h2>
                <div class="bg-white p-4 sm:p-6 md:p-8 rounded-2xl shadow-lg" style="max-width: 1080px; margin-left: auto; margin-right: auto;">
                    <script type='text/javascript' src='https://reputationhub.site/reputation/assets/review-widget.js' is:inline></script>
                    <iframe class='lc_reviews_widget' src='https://reputationhub.site/reputation/widgets/review_widget/cmjlzerv4DUDyZFj6PYO?widgetId=68173d384ec35400c369663a' frameborder='0' scrolling='no' style='min-width: 100%; width: 100%;'></iframe>
                </div>
            </div>
        </section>

        <!-- Video Testimonials Section -->
        <section class="py-16 md:py-20 bg-white full-bleed-section-ghl">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Hear Directly From Our Students</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    
                    <!-- Harleen Kaur -->
                    <div class="bg-gray-50 rounded-2xl shadow-md overflow-hidden flex flex-col">
                        <video controls class="w-full"><source src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/688519f4b8876823a8e18d3c.mp4" type="video/mp4"></video>
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="font-bold text-lg text-gray-800">Harleen Kaur</h3>
                            <p class="text-sm text-gray-500 mb-3">Toronto, ON</p>
                            <blockquote class="italic text-gray-600 flex-grow">"With all his guidance and remarks, I scored 7 in speaking, 8 in listening, 9 in reading and 10 in writing in TEF Canada exam and this helped me to increase my CRS score for Canadian PR."</blockquote>
                        </div>
                    </div>

                    <!-- Parmeet Singh -->
                    <div class="bg-gray-50 rounded-2xl shadow-md overflow-hidden flex flex-col">
                        <video controls class="w-full"><source src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/688519f46d2fd3019fb8adc8.mp4" type="video/mp4"></video>
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="font-bold text-lg text-gray-800">Parmeet Singh</h3>
                            <p class="text-sm text-gray-500 mb-3">Toronto, ON</p>
                            <blockquote class="italic text-gray-600 flex-grow">"I notice the difference that I have got, a lot of motivation and amazing community which always kept me going."</blockquote>
                        </div>
                    </div>

                    <!-- Bismanjit Singh -->
                    <div class="bg-gray-50 rounded-2xl shadow-md overflow-hidden flex flex-col">
                        <video controls class="w-full"><source src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/688519f4a9387ed5495d6a25.mp4" type="video/mp4"></video>
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="font-bold text-lg text-gray-800">Bismanjit Singh</h3>
                            <p class="text-sm text-gray-500 mb-3">Vancouver, BC</p>
                            <blockquote class="italic text-gray-600 flex-grow">"Vyom and Frenchify has been very helpful throughout and that has helped me a lot in staying consistent and accountable."</blockquote>
                        </div>
                    </div>
                    
                    <!-- Achintya Mishra -->
                    <div class="bg-gray-50 rounded-2xl shadow-md overflow-hidden flex flex-col">
                        <video controls class="w-full"><source src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/688519f46d2fd3a629b8adc9.mp4" type="video/mp4"></video>
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="font-bold text-lg text-gray-800">Achintya Mishra</h3>
                            <p class="text-sm text-gray-500 mb-3">Toronto, ON</p>
                            <blockquote class="italic text-gray-600 flex-grow">"My experience with Vyom has been a very wonderful journey, the best thing is the flexibility and the way of teaching. As an Indian student on work permit, he makes it achievable to get a PR."</blockquote>
                        </div>
                    </div>

                    <!-- Shivya Kakkar -->
                    <div class="bg-gray-50 rounded-2xl shadow-md overflow-hidden flex flex-col">
                        <video controls class="w-full"><source src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/688519f45468fc1cb4e9e695.mp4" type="video/mp4"></video>
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="font-bold text-lg text-gray-800">Shivya Kakkar</h3>
                            <p class="text-sm text-gray-500 mb-3">Toronto, ON</p>
                            <blockquote class="italic text-gray-600 flex-grow">"I found the Frenchify programs to be very learnable... Everything in the courses are put in with efforts so you can easily refer back to anything you get confused in. Thank you for providing such a great community."</blockquote>
                        </div>
                    </div>

                    <!-- Selena Diaz -->
                    <div class="bg-gray-50 rounded-2xl shadow-md overflow-hidden flex flex-col">
                        <video controls class="w-full"><source src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/688519f4a9387e32e05d6a23.mp4" type="video/mp4"></video>
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="font-bold text-lg text-gray-800">Selena Diaz</h3>
                            <p class="text-sm text-gray-500 mb-3">Barrie, ON</p>
                            <blockquote class="italic text-gray-600 flex-grow">"I wanted better job opportunities... what I like about this course is the flexibility of learning. Vyom also has Q&A sessions, tests and everything is done from basics."</blockquote>
                        </div>
                    </div>

                    <!-- Jeni Francis -->
                    <div class="bg-gray-50 rounded-2xl shadow-md overflow-hidden flex flex-col">
                        <video controls class="w-full"><source src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/688519f493322425174513c0.mp4" type="video/mp4"></video>
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="font-bold text-lg text-gray-800">Jeni Francis</h3>
                            <p class="text-sm text-gray-500 mb-3"> </p> <!-- Placeholder for location if needed -->
                            <blockquote class="italic text-gray-600 flex-grow">"It's been very comfortable learning in weekly classes with Vyom. The ease of learning with the strategy that Vyom tells is crazy."</blockquote>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- Final CTA Section -->
        <section class="py-16 md:py-20 bg-gray-800 text-white full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h2 class="text-3xl font-bold mb-4">Ready to Start Your Own Success Story?</h2>
                <p class="text-lg text-gray-300 mb-8">Join hundreds of successful students and achieve your French language goals. Explore our programs today.</p>
                <a href="/programs" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300">
                    Explore Our Courses
                </a>
            </div>
        </section>
    </main>
</Layout>
