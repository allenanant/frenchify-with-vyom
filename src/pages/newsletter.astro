---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Subscribe to Frenchify Newsletter">
<!-- Header -->
    

    <!-- Main Content -->
    <main class="pt-20 min-h-screen flex items-center justify-center px-4">
        <div class="max-w-4xl mx-auto text-center">
            <!-- Header Section -->
            <div class="mb-12">
                <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-100 rounded-full mb-6">
                    <i class="fas fa-envelope text-blue-600 text-2xl"></i>
                </div>
                <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight">
                    Stay Updated with
                    <span class="text-blue-600">Frenchify</span>
                </h1>
                <p class="text-xl text-gray-600 mb-4 max-w-2xl mx-auto leading-relaxed">
                    Get the latest French learning tips, TEF/TCF exam strategies, and exclusive content delivered straight to your inbox.
                </p>
                <div class="flex flex-wrap justify-center gap-6 text-sm text-gray-500 mb-8">
                    <div class="flex items-center">
                        <i class="fas fa-check-circle text-green-500 mr-2"></i>
                        Weekly French Tips
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-check-circle text-green-500 mr-2"></i>
                        Exam Strategies
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-check-circle text-green-500 mr-2"></i>
                        Student Success Stories
                    </div>
                </div>
            </div>

            <!-- Form Container -->
            <div class="bg-white rounded-2xl shadow-xl p-8 md:p-12 max-w-lg mx-auto border border-gray-100">
                <div class="mb-6">
                    <h2 class="text-2xl font-semibold text-gray-900 mb-2">Join Our Community</h2>
                    <p class="text-gray-600">Subscribe to receive valuable French learning resources</p>
                </div>

                <!-- Newsletter Form -->
                <div class="newsletter-form">
                    <iframe
                        src="https://api.leadconnectorhq.com/widget/form/DqCZ5admvl0tPdrDgsok"
                        style="width:100%;height:411px;border:none;border-radius:12px"
                        id="inline-DqCZ5admvl0tPdrDgsok"
                        data-layout="{'id':'INLINE'}"
                        data-trigger-type="alwaysShow"
                        data-trigger-value=""
                        data-activation-type="alwaysActivated"
                        data-activation-value=""
                        data-deactivation-type="neverDeactivate"
                        data-deactivation-value=""
                        data-form-name="Email Newsletter"
                        data-height="411"
                        data-layout-iframe-id="inline-DqCZ5admvl0tPdrDgsok"
                        data-form-id="DqCZ5admvl0tPdrDgsok"
                        title="Email Newsletter">
                    </iframe>
                </div>

                <div class="mt-6 text-xs text-gray-500 text-center">
                    <i class="fas fa-lock mr-1"></i>
                    We respect your privacy. Unsubscribe at any time.
                </div>
            </div>

            <!-- Additional Benefits -->
            <div class="mt-12 grid md:grid-cols-3 gap-6 text-center">
                <div class="p-6">
                    <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-graduation-cap text-blue-600"></i>
                    </div>
                    <h3 class="font-semibold text-gray-900 mb-2">Expert Tips</h3>
                    <p class="text-gray-600 text-sm">Get proven strategies from Vyom's successful TEF journey</p>
                </div>
                <div class="p-6">
                    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-users text-green-600"></i>
                    </div>
                    <h3 class="font-semibold text-gray-900 mb-2">Community Access</h3>
                    <p class="text-gray-600 text-sm">Connect with fellow French learners and share experiences</p>
                </div>
                <div class="p-6">
                    <div class="w-12 h-12 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-gift text-purple-600"></i>
                    </div>
                    <h3 class="font-semibold text-gray-900 mb-2">Exclusive Content</h3>
                    <p class="text-gray-600 text-sm">Access subscriber-only resources and special offers</p>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
</Layout>
