---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Frequently Asked Questions - Frenchify">
<main>
        <!-- Hero Section -->
        <section class="py-16 md:py-20 !pt-[124px] md:!pt-[140px] bg-white full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h1>
                <p class="text-lg text-gray-600 max-w-3xl mx-auto">
                    Find answers to common questions about our programs, the TEF exam, and more.
                </p>
            </div>
        </section>

        <!-- Category Navigation -->
        <section class="bg-white border-b border-gray-200 sticky top-0 z-40 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <nav class="flex justify-center space-x-4 md:space-x-8">
                    <a href="#programs" class="py-4 px-1 text-gray-600 font-medium hover:text-blue-600 border-b-2 border-transparent hover:border-blue-600 transition-colors duration-200">Frenchify Programs</a>
                    <a href="#exam" class="py-4 px-1 text-gray-600 font-medium hover:text-blue-600 border-b-2 border-transparent hover:border-blue-600 transition-colors duration-200">TEF/TCF Exam</a>
                    <a href="#general" class="py-4 px-1 text-gray-600 font-medium hover:text-blue-600 border-b-2 border-transparent hover:border-blue-600 transition-colors duration-200">General</a>
                </nav>
            </div>
        </section>

        <!-- FAQ Content Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">

                <!-- Frenchify Programs Category -->
                <div id="programs">
                    <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-8 border-b border-gray-200 pb-4">Frenchify Programs</h2>
                    <div class="space-y-4">
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Does Frenchify Program offer TEF/TCF or TEFAQ training?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">Yes, exam-specific training is provided right from the start and the programs are designed in a way to fast-track the preparation.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">How much time does it take to clear TEF with Frenchify?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">If you study an average of 2-3 hours daily, A1 & A2 can be completed within 3 months, and B1 & B2 within 5-6 months. If you are studying French full-time, the time frame reduces.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Is the speaking module covered in the A1 level?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">Yes, speaking tasks are given right from the A1 level to build foundational conversational skills.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Is there an exam conducted after each level at Frenchify?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">Yes, a student has to pass a level-specific exam conducted at Frenchify by Vyom to be promoted to the next level.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Does the Frenchify Program have doubt sessions?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">Yes. Along with the online programs, we provide 4 live doubt sessions each week for better understanding and mentorship.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">At what level does TEF/TCF-specific training start in Frenchify?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">At B1 level, mock exam practices begin with sessions focusing on exam-specific preparation covering all 4 modules (Reading, Writing, Speaking, Listening).</p></div></div>
                    </div>
                </div>

                <!-- TEF/TCF Exam Category -->
                <div id="exam">
                    <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-8 border-b border-gray-200 pb-4">TEF/TCF Exam</h2>
                    <div class="space-y-4">
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Do we need to give level-specific exams for TEF/TCF?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">No, you don't need to give exams after each level. They only want your overall score to be CLB/NCLC 5 or 7, depending on the immigration stream.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Is the IELTS and TEF exam same/similar?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">They both have the same four modules (Reading, Writing, Speaking & Listening), but they have different formats. For example, the TEF exam has only MCQ answer options in Reading and Listening.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Where can I find mock tests for the TEF exam?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">PrepMyFuture offers 3 exact sample tests like the official TEF, which can be solved for practice.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Can I give each module individually if I score less in one?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">No. Unlike IELTS, you cannot give each module separately. You need to re-attempt all 4 modules if you score less in any of the sections.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Which level is required for the French Immigration Stream?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">CLB/NCLC 7 is required, which is equivalent to a B2+ level in French.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">How long are the results of TEF & TCF valid?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">The results for both TEF and TCF are valid for 2 years.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">What is the main difference between the TEF & TCF French exam?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">The main differences are the time allotted to each module, the format of questions, and the number of questions.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">How many times can I give these exams?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">A student can attempt the exams multiple times; there is no limit. However, there must be a waiting period of 30 days between 2 test attempts.</p></div></div>
                    </div>
                </div>

                <!-- General Category -->
                <div id="general">
                    <h2 class="text-2xl md:text-3xl font-bold text-gray-800 mb-8 border-b border-gray-200 pb-4">General</h2>
                    <div class="space-y-4">
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">How do I keep myself motivated while learning French?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">Join community groups to find study partners, get mentorship to reduce prep time, and focus on all 4 skills (reading, writing, speaking, listening) at regular intervals to avoid getting bored of only grammar and vocabulary.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Does Frenchify with Vyom offer one-on-one coaching?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">I don't personally recommend one-on-one sessions as they can stretch your learning time and be expensive. With busy schedules, it is often better to go with group-based flexible programs. You can book a meeting to know more.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">How can I begin learning if I am a beginner and want to self-study?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">You can register on our website for the Free Beginner Program, which provides a detailed outline, books, and resources for the self-study method.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Do I really need to join coaching, or can I do it by myself?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">It is possible to self-learn up to a beginner level, but for intermediate levels, proper guidance is required, especially for the Speaking and Writing modules. Self-study typically takes longer (6-8 months for A1/A2), whereas with coaching, you can do it within 3 months.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Can I clear French from beginner in 6 months if I study for 12 hours daily?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">This is not recommended as it is mentally draining. If you are studying full-time (no job, no college), you can attain CLB 5-6, depending on your practice and consistency.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">Can I get a bilingual job if I am at the B1 level?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">Yes, depending on your job profile, especially in customer service. Employers will likely check your language fluency during the interview, and your official TEF/TCF/DELF results will be very helpful.</p></div></div>
                        <div class="faq-item bg-white rounded-lg shadow-sm border border-gray-200"><button class="faq-toggle w-full text-left p-6 flex justify-between items-center"><span class="font-semibold text-gray-800">How do I get free books and resources for French learning?</span><i class="fas fa-chevron-down transform transition-transform"></i></button><div class="faq-content max-h-0 overflow-hidden"><p class="p-6 pt-0 text-gray-600">You can find them on our website under the Programs Page, in the "Free learning resources" Tab.</p></div></div>
                    </div>
                </div>

            </div>
        </section>

        <!-- Final CTA Section -->
        <section class="py-16 md:py-20 bg-gray-800 text-white full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h2 class="text-3xl font-bold mb-4">Still Have Questions?</h2>
                <p class="text-lg text-gray-300 mb-8">Our team is here to help. Book a consultation to get personalized advice for your French learning journey.</p>
                <a href="/contact" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300">
                    Book a Consultation
                </a>
            </div>
        </section>

    </main>

  <script slot="scripts" is:inline>
// FAQ accordion toggle
        const faqToggles = document.querySelectorAll('.faq-toggle');
        faqToggles.forEach(toggle => {
            toggle.addEventListener('click', () => {
                const content = toggle.parentElement.querySelector('.faq-content');
                const icon = toggle.querySelector('i');

                // Close all other open FAQs
                faqToggles.forEach(otherToggle => {
                    if (otherToggle !== toggle) {
                        const otherContent = otherToggle.parentElement.querySelector('.faq-content');
                        const otherIcon = otherToggle.querySelector('i');
                        if (otherContent.style.maxHeight) {
                            otherContent.style.maxHeight = null;
                            otherIcon.classList.remove('rotate-180');
                        }
                    }
                });

                // Toggle the clicked FAQ
                if (content.style.maxHeight) {
                    content.style.maxHeight = null;
                    icon.classList.remove('rotate-180');
                } else {
                    content.style.maxHeight = content.scrollHeight + "px";
                    icon.classList.add('rotate-180');
                }
            });
        });
  </script>
</Layout>
