---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us - Frenchify with Vyom">
<main>
        <!-- Hero Section -->
        <section class="pt-[calc(4rem+30px)] md:pt-[calc(5rem+30px)] pb-16 md:pb-20 bg-white full-bleed-section-ghl">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid lg:grid-cols-2 gap-12 items-center">
                    <div class="text-center lg:text-left order-2 lg:order-1">
                        <h1 class="text-4xl md:text-5xl font-bold text-gray-900">Meet Your Guide: Vyom Sharma</h1>
                        <p class="mt-4 text-lg text-gray-600">My goal is simple: to help you navigate the path to Canadian PR through French, just like I did.</p>
                        <div class="mt-6">
                            <a href="/programs" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-0.5">
                                <span>Start Your Journey</span>
                                <i class="fas fa-arrow-right ml-2"></i>
                            </a>
                        </div>
                    </div>
                    <div class="flex justify-center order-1 lg:order-2">
                        <img src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/6808d65bdf54eff4377e2466.png" alt="Vyom Sharma - French Language Instructor" class="rounded-2xl shadow-2xl w-72 h-80 object-cover object-center border-4 border-white">
                    </div>
                </div>
            </div>
        </section>

        <!-- Mission Section -->
        <section class="py-16 md:py-20 bg-blue-600 text-white full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <i class="fas fa-rocket text-4xl mb-4 text-blue-200"></i>
                <h2 class="text-3xl font-bold mb-4">Our Mission: Making French Accessible for Every Immigrant</h2>
                <p class="text-lg text-blue-100">
                    To empower aspiring immigrants in Canada by guiding them through the journey of learning French with clarity, confidence, and community. Drawing from his own experience, Vyom is committed to helping others unlock new opportunities—like boosting CRS scores and achieving permanent residency—through easy & effective French education.
                </p>
            </div>
        </section>

        <!-- Journey Timeline Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-16">My French Learning Journey</h2>
                <div class="relative">
                    <!-- The vertical line - hidden on mobile -->
                    <div class="absolute left-1/2 -ml-0.5 w-1 bg-blue-100 h-full hidden md:block" aria-hidden="true"></div>
                    <!-- Mobile vertical line -->
                    <div class="absolute left-6 top-0 w-0.5 bg-blue-100 h-full md:hidden" aria-hidden="true"></div>

                    <div class="space-y-6 md:space-y-12">
                        <!-- Timeline Item 1 -->
                        <div class="relative">
                            <!-- Mobile layout -->
                            <div class="flex md:hidden items-start">
                                <div class="flex-shrink-0 w-6 h-6 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs relative z-10 mt-1">
                                    <i class="fas fa-graduation-cap text-xs"></i>
                                </div>
                                <div class="ml-4 flex-1">
                                    <div class="p-4 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800 text-sm mb-1">28th Dec, 2018</p>
                                        <p class="text-gray-600 text-sm leading-relaxed">Arrived in Canada as an International student after 12th Grade.</p>
                                    </div>
                                </div>
                            </div>
                            <!-- Desktop layout -->
                            <div class="hidden md:flex items-center justify-end md:odd:flex-row-reverse">
                                <div class="w-1/2 pr-8 text-right">
                                    <div class="p-6 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800">28th Dec, 2018</p>
                                        <p class="text-gray-600">Arrived in Canada as an International student after 12th Grade.</p>
                                    </div>
                                </div>
                                <div class="absolute left-1/2 -ml-4 h-8 w-8 rounded-full bg-blue-600 flex items-center justify-center text-white">
                                    <i class="fas fa-graduation-cap"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Timeline Item 2 -->
                        <div class="relative">
                            <!-- Mobile layout -->
                            <div class="flex md:hidden items-start">
                                <div class="flex-shrink-0 w-6 h-6 bg-blue-600 rounded-full flex items-center justify-center text-white text-xs relative z-10 mt-1">
                                    <i class="fas fa-briefcase text-xs"></i>
                                </div>
                                <div class="ml-4 flex-1">
                                    <div class="p-4 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800 text-sm mb-1">1st Nov, 2020</p>
                                        <p class="text-gray-600 text-sm leading-relaxed">Got my Work Permit and a Full-Time field job.</p>
                                    </div>
                                </div>
                            </div>
                            <!-- Desktop layout -->
                            <div class="hidden md:flex items-center justify-start">
                                <div class="w-1/2 pl-8">
                                    <div class="p-6 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800">1st Nov, 2020</p>
                                        <p class="text-gray-600">Got my Work Permit and a Full-Time field job.</p>
                                    </div>
                                </div>
                                <div class="absolute left-1/2 -ml-4 h-8 w-8 rounded-full bg-blue-600 flex items-center justify-center text-white">
                                    <i class="fas fa-briefcase"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Timeline Item 3 -->
                        <div class="relative">
                            <!-- Mobile layout -->
                            <div class="flex md:hidden items-start">
                                <div class="flex-shrink-0 w-6 h-6 bg-orange-500 rounded-full flex items-center justify-center text-white text-xs relative z-10 mt-1">
                                    <i class="fas fa-lightbulb text-xs"></i>
                                </div>
                                <div class="ml-4 flex-1">
                                    <div class="p-4 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800 text-sm mb-1">9th April, 2021</p>
                                        <p class="text-gray-600 text-sm leading-relaxed">On my birthday, a friend shared how French could help my PR application.</p>
                                    </div>
                                </div>
                            </div>
                            <!-- Desktop layout -->
                            <div class="hidden md:flex items-center justify-end md:odd:flex-row-reverse">
                                <div class="w-1/2 pr-8 text-right">
                                    <div class="p-6 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800">9th April, 2021</p>
                                        <p class="text-gray-600">On my birthday, a friend shared how French could help my PR application.</p>
                                    </div>
                                </div>
                                <div class="absolute left-1/2 -ml-4 h-8 w-8 rounded-full bg-orange-500 flex items-center justify-center text-white">
                                    <i class="fas fa-lightbulb"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Timeline Item 4 -->
                        <div class="relative">
                            <!-- Mobile layout -->
                            <div class="flex md:hidden items-start">
                                <div class="flex-shrink-0 w-6 h-6 bg-yellow-500 rounded-full flex items-center justify-center text-white text-xs relative z-10 mt-1">
                                    <i class="fas fa-book text-xs"></i>
                                </div>
                                <div class="ml-4 flex-1">
                                    <div class="p-4 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800 text-sm mb-1">Aug, 2021</p>
                                        <p class="text-gray-600 text-sm leading-relaxed">Self-learned for 4 months for A1 & A2 but stopped due to a lack of proper guidance.</p>
                                    </div>
                                </div>
                            </div>
                            <!-- Desktop layout -->
                            <div class="hidden md:flex items-center justify-start">
                                <div class="w-1/2 pl-8">
                                    <div class="p-6 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800">Aug, 2021</p>
                                        <p class="text-gray-600">Self-learned for 4 months for A1 & A2 but stopped due to a lack of proper guidance.</p>
                                    </div>
                                </div>
                                <div class="absolute left-1/2 -ml-4 h-8 w-8 rounded-full bg-yellow-500 flex items-center justify-center text-white">
                                    <i class="fas fa-book"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Timeline Item 5 -->
                        <div class="relative">
                            <!-- Mobile layout -->
                            <div class="flex md:hidden items-start">
                                <div class="flex-shrink-0 w-6 h-6 bg-green-500 rounded-full flex items-center justify-center text-white text-xs relative z-10 mt-1">
                                    <i class="fas fa-bullseye text-xs"></i>
                                </div>
                                <div class="ml-4 flex-1">
                                    <div class="p-4 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800 text-sm mb-1">Feb, 2022</p>
                                        <p class="text-gray-600 text-sm leading-relaxed">Resumed my self-learning journey with proper goal setting and renewed focus.</p>
                                    </div>
                                </div>
                            </div>
                            <!-- Desktop layout -->
                            <div class="hidden md:flex items-center justify-end md:odd:flex-row-reverse">
                                <div class="w-1/2 pr-8 text-right">
                                    <div class="p-6 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800">Feb, 2022</p>
                                        <p class="text-gray-600">Resumed my self-learning journey with proper goal setting and renewed focus.</p>
                                    </div>
                                </div>
                                <div class="absolute left-1/2 -ml-4 h-8 w-8 rounded-full bg-green-500 flex items-center justify-center text-white">
                                    <i class="fas fa-bullseye"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Timeline Item 6 -->
                        <div class="relative">
                            <!-- Mobile layout -->
                            <div class="flex md:hidden items-start">
                                <div class="flex-shrink-0 w-6 h-6 bg-yellow-400 rounded-full flex items-center justify-center text-white text-xs relative z-10 mt-1">
                                    <i class="fas fa-medal text-xs"></i>
                                </div>
                                <div class="ml-4 flex-1">
                                    <div class="p-4 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800 text-sm mb-1">13th Sept, 2022</p>
                                        <p class="text-gray-600 text-sm leading-relaxed">Passed my TEF exam with B2 and C1 levels.</p>
                                    </div>
                                </div>
                            </div>
                            <!-- Desktop layout -->
                            <div class="hidden md:flex items-center justify-start">
                                <div class="w-1/2 pl-8">
                                    <div class="p-6 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800">13th Sept, 2022</p>
                                        <p class="text-gray-600">Passed my TEF exam with B2 and C1 levels.</p>
                                    </div>
                                </div>
                                <div class="absolute left-1/2 -ml-4 h-8 w-8 rounded-full bg-yellow-400 flex items-center justify-center text-white">
                                    <i class="fas fa-medal"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Timeline Item 7 -->
                        <div class="relative">
                            <!-- Mobile layout -->
                            <div class="flex md:hidden items-start">
                                <div class="flex-shrink-0 w-6 h-6 bg-red-600 rounded-full flex items-center justify-center text-white text-xs relative z-10 mt-1">
                                    <i class="fab fa-canadian-maple-leaf text-xs"></i>
                                </div>
                                <div class="ml-4 flex-1">
                                    <div class="p-4 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800 text-sm mb-1">9th Nov, 2022</p>
                                        <p class="text-gray-600 text-sm leading-relaxed">Got my PR invitation with 62 extra points for French!</p>
                                    </div>
                                </div>
                            </div>
                            <!-- Desktop layout -->
                            <div class="hidden md:flex items-center justify-end md:odd:flex-row-reverse">
                                <div class="w-1/2 pr-8 text-right">
                                    <div class="p-6 bg-white rounded-lg shadow-lg">
                                        <p class="font-bold text-gray-800">9th Nov, 2022</p>
                                        <p class="text-gray-600">Got my PR invitation with 62 extra points for French!</p>
                                    </div>
                                </div>
                                <div class="absolute left-1/2 -ml-4 h-8 w-8 rounded-full bg-red-600 flex items-center justify-center text-white">
                                    <i class="fab fa-canadian-maple-leaf"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Video Section -->
        <section class="py-16 md:py-20 bg-white full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h2 class="text-3xl font-bold text-gray-900 mb-8">Watch The Full Story</h2>
                <div class="video-container rounded-2xl shadow-2xl overflow-hidden">
                    <iframe
                        src="https://www.youtube.com/embed/4nMBI53-7Uw"
                        title="Vyom's French Learning Journey - Frenchify"
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen>
                    </iframe>
                </div>
            </div>
        </section>

        <!-- Photo Gallery Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
             <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Moments From The Journey</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <img src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/6808e5af92612101acc2eb1b.jpeg" alt="Frenchify students" class="rounded-xl shadow-lg w-full h-full object-cover transform hover:scale-105 transition-transform duration-300">
                    <img src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/6808e5afbcc5c4159279e282.jpeg" alt="Frenchify event" class="rounded-xl shadow-lg w-full h-full object-cover transform hover:scale-105 transition-transform duration-300">
                    <img src="https://storage.googleapis.com/msgsndr/cmjlzerv4DUDyZFj6PYO/media/6808e6658ee8cd77a2cba4b7.jpeg" alt="Frenchify community" class="rounded-xl shadow-lg w-full h-full object-cover transform hover:scale-105 transition-transform duration-300">
                </div>
            </div>
        </section>

        <!-- Final CTA Section -->
        <section class="py-16 md:py-20 bg-gray-800 text-white full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h2 class="text-3xl font-bold mb-4">Ready to Start Your Journey?</h2>
                <p class="text-lg text-gray-300 mb-8">Let's work together to achieve your language goals and unlock your path to Canadian PR.</p>
                <a href="/programs" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300">
                    Explore Courses
                </a>
            </div>
        </section>
    </main>

  <style is:global>
/* Specific fix for Video Aspect Ratio */
        .video-container {
            position: relative;
            width: 100%;
            height: 0;
            padding-bottom: 56.25%; /* 16:9 aspect ratio */
        }

        .video-container iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }
  </style>
</Layout>
