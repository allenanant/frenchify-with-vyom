---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Frenchify B1 Self-Study (TEF) Program">
<!-- Header -->
    

    <main>
        <!-- Hero Section -->
        <section class="py-16 md:py-24 bg-gray-50 hero-pattern full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Frenchify B1 Self-Study (TEF) Program</h1>
                <p class="text-xl md:text-2xl text-blue-600 font-medium mb-6">Your Foundation for TEF Canada Success & Achieving CLB 5 for Work Permit Extension</p>
                <p class="text-lg text-gray-600 max-w-3xl mx-auto mb-8">
                    This program is designed for learners who want flexible, self-paced preparation while still getting expert guidance for their TEF journey. Build a strong base in advanced grammar, practice RSWL skills, and prepare for the TEF exam with confidence — anytime, anywhere.
                </p>
                 <a href="https://wa.me/15147265114?text=Hi%2C%20I'm%20interested%20in%20the%20B1%20Self-Study%20program%20and%20would%20like%20to%20book%20my%20analysis%20test." target="_blank" rel="noopener noreferrer" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300">
                    Book my Analysis Test
                </a>
            </div>
        </section>

        <!-- Goals Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Your B1 Self-Study Program Goal: Mastery at Your Pace</h2>
                <ul class="space-y-6">
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Master Advanced Grammar</h3><p class="text-gray-600">Build a deep understanding of B1 and B2 level grammar with clear explanations.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Strengthen Speaking & Writing Fluency</h3><p class="text-gray-600">Get personalized 5 writing feedbacks and 3 one-on-one speaking sessions to refine your structure, fluency, and confidence. More available at an extra fee.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Sharpen Reading & Listening Skills</h3><p class="text-gray-600">Learn to understand authentic conversations and texts with extensive real TEF preparation resources and brochures.</p></div></li>
                </ul>
            </div>
        </section>

        <!-- Program Components Section -->
        <section class="py-16 md:py-20 bg-gray-50 full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12">
                     <h2 class="text-3xl font-bold text-gray-900">Program is Divided into 2 Components</h2>
                     <p class="mt-4 text-lg text-gray-600">Combine a self-paced online course with personalized mentorship opportunities.</p>
                </div>
                <div class="grid lg:grid-cols-2 gap-8 items-stretch">
                    <!-- Online Program Card -->
                    <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 flex flex-col">
                        <div class="flex-shrink-0"><i class="fas fa-laptop-code text-4xl text-blue-600 mb-4"></i></div>
                        <h3 class="text-2xl font-bold text-gray-800 mb-4">📚 Online Course</h3>
                        <p class="text-gray-600 mb-6 flex-grow">Work through the complete B1/B2 curriculum on your own schedule.</p>
                        <ul class="space-y-3 text-gray-700">
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Full B1/B2 Advanced Grammar</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Structured RSWL Modules</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Listening/Reading Resources for TEF</li>
                        </ul>
                    </div>
                    <!-- Speaking & Writing Support Card -->
                    <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 flex flex-col">
                        <div class="flex-shrink-0"><i class="fas fa-microphone-alt text-4xl text-blue-600 mb-4"></i></div>
                        <h3 class="text-2xl font-bold text-gray-800 mb-4">🎤 Speaking & Writing Support</h3>
                        <div class="space-y-4 flex-grow">
                            <p class="text-gray-600">✓ 3 One-on-One Speaking Sessions (25 minutes each) included</p>
                            <p class="text-gray-600">✓ 5 Personalized Writing Feedbacks for Section A practice</p>

                            <p class="text-gray-600">✓ Additional speaking sessions available at:<br>
                                &nbsp;&nbsp;&nbsp;• 25 Mins - $15.99 per session<br>
                                &nbsp;&nbsp;&nbsp;• 50 Mins - $25.99 per session
                            </p>

                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Access, Pricing & Final CTA -->
        <section class="py-16 md:py-20 bg-gray-800 text-white full-bleed-section-ghl" id="signup">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <div class="grid md:grid-cols-2 gap-8 mb-12">
                    <!-- Access Duration -->
                    <div class="bg-gray-900/50 p-8 rounded-2xl border border-gray-700">
                        <div class="flex justify-center items-center gap-4 mb-4">
                            <i class="fas fa-calendar-alt text-3xl text-blue-400"></i>
                            <h3 class="text-2xl font-bold">4-Month Full Access</h3>
                        </div>
                        <p class="text-gray-300">Enjoy 4 months of full access to the online course and your 3 complimentary speaking sessions, plus 5 writing feedbacks (worth $120). Renew anytime if you need extra time or additional practice.</p>
                    </div>
                     <!-- Pricing -->
                    <div class="bg-gray-900/50 p-8 rounded-2xl border border-gray-700">
                        <div class="flex justify-center items-center gap-4 mb-4">
                            <i class="fas fa-dollar-sign text-3xl text-blue-400"></i>
                            <h3 class="text-2xl font-bold">Pricing</h3>
                        </div>
                        <p class="text-3xl font-bold text-white mb-2">$599 CAD</p>
                        <p class="text-gray-300">Includes 4 months of full access, 3 one-on-one speaking sessions, and 5 detailed writing feedbacks — all worth $120 in added value.</p>
                    </div>
                </div>

                <!-- Analysis Test Info -->
                <div class="bg-blue-900/30 p-8 rounded-2xl mb-12 border border-blue-700 text-left">
                    <h3 class="text-2xl font-bold mb-4 text-center">What happens in this Analysis Test?</h3>
                    <ul class="space-y-3 text-gray-200 list-inside">
                        <li><span class="font-semibold text-white">1. On-spot Speaking Test for fluency</span> (3 to 4 minutes)</li>
                        <li><span class="font-semibold text-white">2. Reading, Listening and Grammar test</span></li>
                    </ul>
                </div>

                <h2 class="text-3xl font-bold mb-4">Ready to Start Your Self-Paced TEF Journey?</h2>
                <p class="text-lg text-gray-300 mb-8">Take the first step towards achieving your goals. Book your analysis to ensure you start at the right level.</p>
                <a href="https://wa.me/15147265114?text=Hi%2C%20I'm%20interested%20in%20the%20B1%20Self-Study%20program%20and%20would%20like%20to%20book%20my%20analysis%20test." target="_blank" rel="noopener noreferrer" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-10 py-4 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 text-lg">
                    Book my Analysis Test
                </a>
                <p class="text-sm text-gray-400 mt-6">Taught in English. Some content may not be translated.</p>
            </div>
        </section>

<!-- FAQs Section -->
<section class="py-16 md:py-20 full-bleed-section-ghl">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Frequently Asked Questions</h2>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Before Joining</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Is there a test to analyze my level?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes! Before enrolling, you need to take a mandatory analysis test with Vyom to confirm your current level. To book your test, send a WhatsApp message to 514-726-5114. To book your test there is a 50$ deposit that you need to pay first that will be credited to your course later if you enroll.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Can I buy the program directly from the website?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">No. This program is not available for direct purchase on the website. You must message 514-726-5114 on WhatsApp first to complete your analysis with Vyom. This ensures you are placed in the right program for your level and goals.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What if I’m not ready for B1 after the analysis?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">No problem — we’ll guide you to start at A2 instead, so you build the right foundation before jumping into advanced concepts or you can self prepare for sometime before we can start B1.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Do I need A2 knowledge before starting B1 Self-Study?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes, at least A2-level concepts are needed. This ensures you can follow the lessons smoothly and make the most of your self-paced learning.</p>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Program Details</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What exactly is included in the B1 Self-Study Program?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">You’ll get 4 months of access to our online platform, which includes:<br><br>Full B1 and B2 advanced grammar lectures<br>RSWL training for reading, speaking, writing, and listening<br>5 personalized writing feedbacks<br>3 one-on-one speaking sessions (25 minutes each)<br>Access to authentic TEF practice resources and brochures</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Are the speaking sessions included in the course fee?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes! Three private 25-minute sessions are included to help you build fluency and confidence.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Can I book more than 3 speaking sessions if I need extra practice?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Absolutely. Additional sessions are available at $15.99 for a 25-minute session and $25.99 for a 50-minute session. A calendar will be shared with you, and you can book extra sessions based on instructor availability.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How does the writing feedback process work?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">You’ll submit your written responses for Section A tasks, and our instructors will provide detailed corrections and suggestions to help you improve step by step.</p>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Learning Process & Duration</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How long does it take to finish the Self-Study Program?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">On average, students complete the program in 3–4 months, depending on their pace and weekly commitment.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How much time should I dedicate each week to see results?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">We recommend 2–3 hours per week to stay consistent and make steady progress. More time can speed up your results.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How is this program different from learning completely on my own?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">With Self-Study, you’re not alone. You get personalized feedback, structured lessons, and speaking sessions that make your learning guided and effective — unlike random self-study methods.</p>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Exam Readiness</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Will this program prepare me for all 4 TEF Canada modules?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes! The program builds reading, speaking, writing, and listening skills, focusing on the patterns and strategies needed for TEF success.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How will I know when I’m ready to book my TEF Canada exam?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Once you’ve completed the main modules and performed well in your mock sessions and writing feedback, we’ll guide you on the right time to book your exam.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What if I only need CLB 5 and not higher?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">This program still works for you. You’ll build the skills for CLB 5 and beyond, ensuring you’re well-prepared if your goals change.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Can I continue after 4 months if I need more time?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes, you can renew your access at a discounted rate if you need more time to complete your preparation.</p>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Promotions or Offers</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Do I get a discount if I refer a friend?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes! For every friend who joins using your referral, you get $35 CAD off your next renewal or course upgrade.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Is there a combo discount if I want to upgrade to the B1 Intensive Program later?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes. If you start with Self-Study and later decide to upgrade to the Intensive Program, we’ll adjust your fee so you don’t pay double for the same content.</p>
                    </div>
                </div>

            </div>
        </div>

    </div>
</section>
<!-- End of FAQs Section -->
<!-- Testimonial Widget -->
        <section class="py-16 md:py-20 bg-gray-50 full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">What Our Students Say</h2>

                <!-- Reputation Hub Widget Code -->
                
                <iframe class='lc_reviews_widget' src='https://reputationhub.site/reputation/widgets/review_widget/cmjlzerv4DUDyZFj6PYO' frameborder='0' scrolling='no' style='min-width: 100%; width: 100%;'></iframe>
                <!-- End of Widget Code -->

            </div>
        </section>
    </main>

  <style is:global>
/* Styles for FAQ Accordion */
        .faq-answer {
            transition: max-height 0.5s ease-in-out, padding 0.5s ease-in-out;
            max-height: 0;
            overflow: hidden;
            padding-top: 0;
            padding-bottom: 0;
        }

        .faq-answer.open {
            max-height: 500px; /* Adjust based on content length */
            padding-top: 0.5rem;
            padding-bottom: 1rem;
        }

        .faq-toggle .fa-chevron-down {
            transition: transform 0.3s ease-in-out;
        }

        .faq-toggle.open .fa-chevron-down {
            transform: rotate(180deg);
        }
  </style>
</Layout>
