---
import Layout from '../layouts/Layout.astro';
---

<Layout title="French Level Analysis Test | Frenchify with Vyom">
<!-- Header -->
    

    <!-- Hero Section -->
    <section class="pt-[122px] md:pt-[152px] pb-16 px-6 full-bleed-section-ghl">
        <div class="max-w-4xl mx-auto text-center">
            <div class="inline-flex items-center gap-2 bg-blue-100 text-blue-700 px-4 py-2 rounded-full text-sm font-medium mb-6">
                <i class="fas fa-clipboard-check"></i>
                <span>Professional French Assessment</span>
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-gray-900 leading-tight mb-6">
                Book Your French Level<br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-blue-400">Analysis Test Today</span>
            </h1>
            <p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-2xl mx-auto">
                Not sure if you're <span class="font-semibold text-blue-600">A1</span>, <span class="font-semibold text-blue-600">A2</span>, <span class="font-semibold text-blue-600">B1</span> or <span class="font-semibold text-blue-600">B2</span>?
            </p>
            <p class="text-lg text-gray-700 mb-8 max-w-xl mx-auto">
                Get a quick professional evaluation of your French level and a clear next step.
            </p>
            <a href="#register" class="inline-flex items-center gap-2 bg-blue-600 text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-blue-700 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 shadow-lg shadow-blue-200">
                <span>Book Your Test Now</span>
                <i class="fas fa-arrow-right"></i>
            </a>
        </div>
    </section>

    <!-- Important Note -->
    <section class="px-6 pb-12 full-bleed-section-ghl">
        <div class="max-w-3xl mx-auto">
            <div class="bg-gradient-to-r from-amber-50 to-yellow-50 border border-amber-200 rounded-2xl p-6 md:p-8">
                <div class="flex items-start gap-4">
                    <div class="flex-shrink-0 w-12 h-12 bg-amber-100 rounded-full flex items-center justify-center">
                        <i class="fas fa-exclamation-circle text-amber-600 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="font-bold text-gray-900 text-lg mb-2">Important Note</h3>
                        <p class="text-gray-700 leading-relaxed">
                            If you have given your TEF/TCF or any other exam, please make sure to <strong>mention and attach the score and exam date</strong> for that as well. Frenchify currently trains specifically for the <strong>TEF Canada Exam</strong>.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- What's Included Section -->
    <section class="px-6 py-16 bg-white full-bleed-section-ghl">
        <div class="max-w-[1170px] mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">What is in the Analysis Test?</h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    A structured check of your French (speaking, listening, reading, grammar and/or vocabulary, depending on your level).
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-6 mb-12">
                <div class="bg-gradient-to-br from-blue-50 to-white border border-blue-100 rounded-2xl p-6 text-center card-hover">
                    <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-layer-group text-blue-600 text-2xl"></i>
                    </div>
                    <h3 class="font-bold text-gray-900 text-lg mb-2">Your Level</h3>
                    <p class="text-gray-600">A1, A2, B1 or B2</p>
                </div>
                <div class="bg-gradient-to-br from-green-50 to-white border border-green-100 rounded-2xl p-6 text-center card-hover">
                    <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-chart-bar text-green-600 text-2xl"></i>
                    </div>
                    <h3 class="font-bold text-gray-900 text-lg mb-2">Strengths & Weaknesses</h3>
                    <p class="text-gray-600">Your key areas identified</p>
                </div>
                <div class="bg-gradient-to-br from-purple-50 to-white border border-purple-100 rounded-2xl p-6 text-center card-hover">
                    <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-compass text-purple-600 text-2xl"></i>
                    </div>
                    <h3 class="font-bold text-gray-900 text-lg mb-2">Next Steps</h3>
                    <p class="text-gray-600">What to focus on next</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section class="px-6 py-16 gradient-bg full-bleed-section-ghl">
        <div class="max-w-[1170px] mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">One-Time Fee for Your Test</h2>
                <p class="text-lg text-gray-600">Choose the test that matches your current level</p>
            </div>

            <div class="grid md:grid-cols-3 gap-6 mb-10">
                <!-- A1 Test Card -->
                <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden card-hover">
                    <div class="bg-gradient-to-r from-blue-500 to-blue-600 p-6 text-white text-center">
                        <span class="text-sm font-medium opacity-90">To begin with A2</span>
                        <h3 class="text-2xl font-bold mt-1">A1 Test</h3>
                    </div>
                    <div class="p-6">
                        <div class="text-center mb-6">
                            <span class="text-4xl font-extrabold text-gray-900">$20</span>
                            <span class="text-gray-500 text-sm ml-1">CAD</span>
                        </div>
                        <button onclick="toggleDetails('a1-details', this)" class="w-full flex items-center justify-center gap-2 text-blue-600 font-medium py-3 border border-blue-200 rounded-xl hover:bg-blue-50 transition-all">
                            <span>Click to Know More</span>
                            <i class="fas fa-chevron-down rotate-icon"></i>
                        </button>
                        <div id="a1-details" class="expand-content text-gray-600">
                            <ul class="space-y-3">
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-check-circle text-green-500 mt-1"></i>
                                    <span>2 Grammar Tests</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-check-circle text-green-500 mt-1"></i>
                                    <span>1 Vocabulary Test</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-clock text-blue-500 mt-1"></i>
                                    <span>Results in 1-3 Business Days</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- A2 Test Card -->
                <div class="bg-white rounded-2xl shadow-lg border-2 border-blue-500 overflow-hidden card-hover relative">
                    <div class="absolute top-0 right-0 bg-yellow-400 text-gray-900 text-xs font-bold px-3 py-1 rounded-bl-lg">
                        POPULAR
                    </div>
                    <div class="bg-gradient-to-r from-blue-600 to-indigo-600 p-6 text-white text-center">
                        <span class="text-sm font-medium opacity-90">To begin with B1</span>
                        <h3 class="text-2xl font-bold mt-1">A2 Test</h3>
                    </div>
                    <div class="p-6">
                        <div class="text-center mb-6">
                            <span class="text-4xl font-extrabold text-gray-900">$25</span>
                            <span class="text-gray-500 text-sm ml-1">CAD</span>
                        </div>
                        <button onclick="toggleDetails('a2-details', this)" class="w-full flex items-center justify-center gap-2 text-blue-600 font-medium py-3 border border-blue-200 rounded-xl hover:bg-blue-50 transition-all">
                            <span>Click to Know More</span>
                            <i class="fas fa-chevron-down rotate-icon"></i>
                        </button>
                        <div id="a2-details" class="expand-content text-gray-600">
                            <ul class="space-y-3">
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-check-circle text-green-500 mt-1"></i>
                                    <span>2 On Spot Speaking Video Submissions</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-check-circle text-green-500 mt-1"></i>
                                    <span>Reading Test</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-check-circle text-green-500 mt-1"></i>
                                    <span>Listening Test</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-check-circle text-green-500 mt-1"></i>
                                    <span>Grammar Test</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-clock text-blue-500 mt-1"></i>
                                    <span>Results in 1-3 Business Days</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- B1 Test Card -->
                <div class="bg-white rounded-2xl shadow-lg border border-gray-100 overflow-hidden card-hover">
                    <div class="bg-gradient-to-r from-indigo-600 to-purple-600 p-6 text-white text-center">
                        <span class="text-sm font-medium opacity-90">To begin with B2</span>
                        <h3 class="text-2xl font-bold mt-1">B1 Test</h3>
                    </div>
                    <div class="p-6">
                        <div class="text-center mb-6">
                            <span class="text-4xl font-extrabold text-gray-900">$35</span>
                            <span class="text-gray-500 text-sm ml-1">CAD</span>
                        </div>
                        <button onclick="toggleDetails('b1-details', this)" class="w-full flex items-center justify-center gap-2 text-blue-600 font-medium py-3 border border-blue-200 rounded-xl hover:bg-blue-50 transition-all">
                            <span>Click to Know More</span>
                            <i class="fas fa-chevron-down rotate-icon"></i>
                        </button>
                        <div id="b1-details" class="expand-content text-gray-600">
                            <ul class="space-y-3">
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-check-circle text-green-500 mt-1"></i>
                                    <span>25 mins Live On Spot Section A + B Speaking Test</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-check-circle text-green-500 mt-1"></i>
                                    <span>2 Listening Exam-Style Mock Tests (from outside portal)</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-check-circle text-green-500 mt-1"></i>
                                    <span>2 Reading Exam-Style Mock Tests (from outside portal)</span>
                                </li>
                                <li class="flex items-start gap-3">
                                    <i class="fas fa-clock text-blue-500 mt-1"></i>
                                    <span>Results in 1-3 Business Days</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Free Test Banner -->
            <div class="bg-gradient-to-r from-green-500 to-emerald-500 rounded-2xl p-6 md:p-8 text-white text-center shadow-xl">
                <div class="flex flex-col md:flex-row items-center justify-center gap-4">
                    <div class="w-14 h-14 bg-white/20 rounded-full flex items-center justify-center">
                        <i class="fas fa-gift text-2xl"></i>
                    </div>
                    <div class="text-center md:text-left">
                        <h3 class="text-xl md:text-2xl font-bold mb-1">Your Analysis Test is Effectively FREE!</h3>
                        <p class="text-green-100">The test fee is deducted from your program price when you enroll. You do need to follow the feedback and start at the mentioned level.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- How to Register Section -->
    <section class="px-6 py-16 bg-white full-bleed-section-ghl" id="register">
        <div class="max-w-3xl mx-auto">
            <div class="text-center mb-12">
                <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">How to Register</h2>
                <p class="text-lg text-gray-600">Follow these simple steps to book your test</p>
            </div>

            <div class="space-y-0">
                <!-- Step 1 -->
                <div class="relative pl-16 pb-10">
                    <div class="step-line"></div>
                    <div class="absolute left-0 top-0 w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-lg">1</div>
                    <div class="bg-gradient-to-br from-blue-50 to-white border border-blue-100 rounded-2xl p-6">
                        <h3 class="font-bold text-gray-900 text-lg mb-2">Send E-Transfer</h3>
                        <p class="text-gray-600 mb-3">Send your payment via e-transfer to:</p>
                        <div class="flex items-center gap-3 bg-white border border-blue-200 rounded-xl px-4 py-3">
                            <i class="fas fa-envelope text-blue-600"></i>
                            <span class="font-mono font-semibold text-blue-700">frenchifyfee@gmail.com</span>
                            <button onclick="copyToClipboard('frenchifyfee@gmail.com')" class="ml-auto text-gray-400 hover:text-blue-600 transition-colors">
                                <i class="fas fa-copy"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Step 2 -->
                <div class="relative pl-16 pb-10">
                    <div class="step-line"></div>
                    <div class="absolute left-0 top-0 w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-lg">2</div>
                    <div class="bg-gradient-to-br from-green-50 to-white border border-green-100 rounded-2xl p-6">
                        <h3 class="font-bold text-gray-900 text-lg mb-2">Take a Screenshot</h3>
                        <p class="text-gray-600">Capture a screenshot of your payment confirmation for verification.</p>
                    </div>
                </div>

                <!-- Step 3 -->
                <div class="relative pl-16 pb-10">
                    <div class="step-line"></div>
                    <div class="absolute left-0 top-0 w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-lg">3</div>
                    <div class="bg-gradient-to-br from-emerald-50 to-white border border-emerald-100 rounded-2xl p-6">
                        <h3 class="font-bold text-gray-900 text-lg mb-2">WhatsApp Your Details</h3>
                        <p class="text-gray-600 mb-3">Send the screenshot along with your:</p>
                        <ul class="space-y-2 mb-4 text-gray-600">
                            <li class="flex items-center gap-2"><i class="fas fa-user text-emerald-500"></i> Name</li>
                            <li class="flex items-center gap-2"><i class="fas fa-envelope text-emerald-500"></i> Email</li>
                            <li class="flex items-center gap-2"><i class="fas fa-phone text-emerald-500"></i> Phone Number</li>
                        </ul>
                        <a href="https://wa.me/15147265114" target="_blank" class="inline-flex items-center gap-2 bg-green-500 text-white px-6 py-3 rounded-xl font-semibold hover:bg-green-600 transition-all shadow-md hover:shadow-lg">
                            <i class="fab fa-whatsapp text-xl"></i>
                            <span>Message on WhatsApp</span>
                        </a>
                        <p class="text-sm text-gray-500 mt-3"><i class="fas fa-phone-alt mr-1"></i> 514-726-5114</p>
                    </div>
                </div>

                <!-- Step 4 -->
                <div class="relative pl-16">
                    <div class="absolute left-0 top-0 w-12 h-12 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold text-lg shadow-lg pulse-border">4</div>
                    <div class="bg-gradient-to-br from-purple-50 to-white border border-purple-100 rounded-2xl p-6">
                        <h3 class="font-bold text-gray-900 text-lg mb-2">Fill the Analysis Test Form</h3>
                        <p class="text-gray-600 mb-4">
                            Once your payment is confirmed, fill out the analysis test form. This will help us understand your current level and tailor the next steps more effectively.
                        </p>

                        <!-- Important Note for Form -->
                        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-4">
                            <div class="flex items-start gap-3">
                                <i class="fas fa-info-circle text-amber-500 mt-0.5"></i>
                                <p class="text-sm text-amber-800"><strong>Note:</strong> Please complete the payment first before filling out the form.</p>
                            </div>
                        </div>

                        <a href="https://forms.gle/i5p95kWPtfN2oyGM9" target="_blank" class="inline-flex items-center gap-2 bg-purple-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-purple-700 transition-all shadow-md hover:shadow-lg mb-4">
                            <i class="fas fa-file-alt text-lg"></i>
                            <span>Fill Analysis Test Form</span>
                            <i class="fas fa-external-link-alt text-sm"></i>
                        </a>

                        <div class="flex items-center gap-3 bg-purple-100 text-purple-700 rounded-xl px-4 py-3 mt-4">
                            <i class="fas fa-clock"></i>
                            <span class="font-medium">Results delivered in 1-3 Business Days</span>
                        </div>

                        <p class="text-sm text-gray-500 mt-4 italic">
                            <i class="fas fa-quote-left text-gray-300 mr-1"></i>
                            Merci beaucoup et bonne chance ! Je me réjouis de vous accompagner dans votre préparation à l'examen TEF Canada.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="px-6 py-16 hero-gradient full-bleed-section-ghl">
        <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Ready to Know Your French Level?</h2>
            <p class="text-blue-100 text-lg mb-8">Take the first step towards your Canadian immigration journey today.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="https://wa.me/15147265114" target="_blank" class="inline-flex items-center justify-center gap-2 bg-white text-blue-600 px-8 py-4 rounded-full font-semibold text-lg hover:bg-gray-100 transition-all shadow-lg">
                    <i class="fab fa-whatsapp text-xl"></i>
                    <span>Register via WhatsApp</span>
                </a>
                <a href="/programs" class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white text-white px-8 py-4 rounded-full font-semibold text-lg hover:bg-white/10 transition-all">
                    <span>View All Courses</span>
                    <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- Footer -->

  <style is:global>
html {
            overflow-x: hidden;
            width: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            width: 100%;
            min-width: 100%;
        }

        .gradient-bg {
            background: linear-gradient(135deg, #eff6ff 0%, #ffffff 50%, #fefce8 100%);
        }

        .hero-gradient {
            background: linear-gradient(135deg, #1e40af 0%, #3b82f6 50%, #60a5fa 100%);
        }

        .card-hover {
            transition: all 0.3s ease;
        }

        .card-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        }

        .expand-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease-out, padding 0.4s ease-out;
        }

        .expand-content.active {
            max-height: 500px;
            padding-top: 1rem;
        }

        .rotate-icon {
            transition: transform 0.3s ease;
        }

        .rotate-icon.active {
            transform: rotate(180deg);
        }

        .step-line {
            position: absolute;
            left: 24px;
            top: 48px;
            bottom: 0;
            width: 2px;
            background: linear-gradient(to bottom, #3b82f6, #93c5fd);
        }

        .pulse-border {
            animation: pulse-border 2s infinite;
        }

        @keyframes pulse-border {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4);
            }
            50% {
                box-shadow: 0 0 0 10px rgba(59, 130, 246, 0);
            }
        }
  </style>
</Layout>
