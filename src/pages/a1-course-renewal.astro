---
import Layout from '../layouts/Layout.astro';
---

<Layout title="A1 Course Renewal - Frenchify with Vyom">
<!-- Header -->
    

    <!-- Main Content -->
    <main class="pb-20 px-4">
        <div class="max-w-4xl mx-auto">
            <!-- Header Section -->
            <div class="text-center mb-12 pt-12">
                <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
                    A1 Course <span class="bg-gradient-to-r from-blue-600 to-yellow-500 bg-clip-text text-transparent">Renewal</span>
                </h1>
                <p class="text-lg text-gray-600">Continue your French learning journey</p>
            </div>

            <!-- Pricing Cards -->
            <div class="grid md:grid-cols-2 gap-8 mb-12">
                <!-- Online Course Only -->
                <div class="bg-white border-2 border-gray-200 rounded-2xl p-8 hover:border-blue-500 hover:shadow-xl transition-all duration-300">
                    <div class="text-center mb-6">
                        <h2 class="text-2xl font-bold text-gray-900 mb-2">A1 - Online Course Renewal</h2>
                        <div class="w-16 h-1 bg-gradient-to-r from-blue-600 to-yellow-500 mx-auto rounded-full"></div>
                    </div>
                    <div class="space-y-4">
                        <div class="flex justify-between items-center p-4 bg-gray-50 rounded-lg">
                            <span class="font-semibold text-gray-700">1 Month</span>
                            <span class="text-2xl font-bold text-blue-600">$99 CAD</span>
                        </div>
                        <div class="flex justify-between items-center p-4 bg-gray-50 rounded-lg">
                            <span class="font-semibold text-gray-700">2 Months</span>
                            <span class="text-2xl font-bold text-blue-600">$149 CAD</span>
                        </div>
                    </div>
                </div>

                <!-- Online Course + Live Sessions -->
                <div class="bg-white border-2 border-yellow-400 rounded-2xl p-8 hover:border-yellow-500 hover:shadow-xl transition-all duration-300 relative">
                    <div class="absolute -top-3 left-1/2 transform -translate-x-1/2">
                        <span class="bg-yellow-400 text-gray-900 px-4 py-1 rounded-full text-sm font-bold">POPULAR</span>
                    </div>
                    <div class="text-center mb-6">
                        <h2 class="text-2xl font-bold text-gray-900 mb-2">A1 Online Course + Live Sessions</h2>
                        <div class="w-16 h-1 bg-gradient-to-r from-blue-600 to-yellow-500 mx-auto rounded-full"></div>
                    </div>
                    <div class="space-y-4">
                        <div class="flex justify-between items-center p-4 bg-yellow-50 rounded-lg">
                            <span class="font-semibold text-gray-700">1 Month</span>
                            <span class="text-2xl font-bold text-blue-600">$149 CAD</span>
                        </div>
                        <div class="flex justify-between items-center p-4 bg-yellow-50 rounded-lg">
                            <span class="font-semibold text-gray-700">2 Months</span>
                            <span class="text-2xl font-bold text-blue-600">$199 CAD</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment Instructions -->
            <div class="bg-gradient-to-br from-blue-50 to-yellow-50 rounded-2xl p-8 mb-8">
                <h3 class="text-2xl font-bold text-gray-900 mb-6 text-center">How to Renew</h3>
                <div class="space-y-4">
                    <div class="flex items-start gap-4">
                        <div class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">1</div>
                        <div>
                            <p class="text-gray-700"><strong>Choose your preferred renewal option</strong> from the packages above</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">2</div>
                        <div>
                            <p class="text-gray-700"><strong>Send the payment</strong> to:</p>
                          <div class="mt-2 bg-white p-4 rounded-lg border-2 border-blue-200">
  <a href="mailto:frenchifyfee@gmail.com"
     class="text-blue-600 font-bold text-lg underline">
     frenchifyfee@gmail.com </a>
                          </div>

                        </div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">3</div>
                        <div>
                            <p class="text-gray-700 mb-3"><strong>Send us a screenshot</strong> of the payment confirmation to begin your access</p>
                            <div class="bg-white p-4 rounded-lg border-2 border-green-200">
                                <p class="text-gray-700 mb-2"><strong>Send via WhatsApp:</strong></p>
                                <a href="https://wa.me/15147265114" target="_blank" class="text-green-600 font-bold text-lg hover:text-green-700 flex items-center gap-2">
                                    <i class="fab fa-whatsapp"></i> +1 (514) 726-5114
                                </a>
                                <p class="text-gray-600 text-sm mt-2">Or send through the Frenchify Portal / App</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Important Notes -->
            <div class="bg-yellow-50 border-2 border-yellow-300 rounded-2xl p-6 mb-8">
                <div class="flex items-start gap-3">
                    <i class="fas fa-exclamation-circle text-yellow-600 text-2xl mt-1"></i>
                    <div>
                        <h4 class="font-bold text-gray-900 mb-2">Important Notes:</h4>
                        <ul class="space-y-2 text-gray-700">
                            <li class="flex items-start gap-2">
                                <span class="text-yellow-600 mt-1">•</span>
                                <span>It is essential to renew right after your course expires to avoid long breaks in your learning</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="text-yellow-600 mt-1">•</span>
                                <span>If you plan to resume study after a specific period, you need to notify Vyom or the Team about your Study Plan moving ahead</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Motivation Section -->
            <div class="text-center bg-gradient-to-r from-blue-600 to-yellow-500 rounded-2xl p-8 text-white">
                <p class="text-xl md:text-2xl font-bold mb-2">Let's make sure that we complete A1 this time</p>
                <p class="text-lg md:text-xl">and start with A2 💯</p>
            </div>
        </div>
    </main>
</Layout>
