---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Frenchify A2 Self-Study Program">
<!-- Header -->
    

    <main>
        <!-- Hero Section -->
        <section class="py-16 md:py-24 bg-gray-50 hero-pattern full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">The Frenchify A2 Self-Study Program</h1>
                <p class="text-xl md:text-2xl text-blue-600 font-medium mb-6">Take Your French to the Next Level — Confidently, at Your Pace</p>
                <p class="text-lg text-gray-600 max-w-3xl mx-auto mb-8">
                   If you've already completed A1 or have a basic foundation in French, this is your next step. Transition from beginner to independent speaker with more complex grammar, richer vocabulary, and deeper communication skills — all on your own schedule.
                </p>
                 <a href="https://link.fastpaydirect.com/payment-link/684971d397daa447de9fc3fd" target="_blank" rel="noopener noreferrer" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-3 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300">
                    Enroll Now
                </a>
            </div>
        </section>

        <!-- Goals Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Our Goal at A2 Is to Help You:</h2>
                <ul class="space-y-6">
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Strengthen Your Understanding</h3><p class="text-gray-600">Master sentence structure and complex grammar rules.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Express Yourself</h3><p class="text-gray-600">Learn to express opinions, preferences, and ideas in French.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Expand Your Vocabulary</h3><p class="text-gray-600">Learn words for daily life, social situations, and work.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Build Reading & Writing Confidence</h3><p class="text-gray-600">Read longer texts and write clear messages with ease.</p></div></li>
                    <li class="flex items-start"><div class="flex-shrink-0 bg-blue-100 p-3 rounded-full mr-4"><i class="fas fa-check text-blue-600"></i></div><div><h3 class="font-semibold text-lg text-gray-800">Improve Listening Skills</h3><p class="text-gray-600">Understand and respond to faster-paced spoken French.</p></div></li>
                </ul>
            </div>
        </section>

        <!-- Program Components Section -->
        <section class="py-16 md:py-20 bg-gray-50 full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-12">
                     <h2 class="text-3xl font-bold text-gray-900">What You Get</h2>
                     <p class="mt-4 text-lg text-gray-600">A comprehensive program designed for real progress and independent learning.</p>
                </div>
                <div class="grid lg:grid-cols-2 gap-8 items-stretch">
                    <!-- Online Course Card -->
                    <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 flex flex-col">
                        <div class="flex-shrink-0"><i class="fas fa-laptop-code text-4xl text-blue-600 mb-4"></i></div>
                        <h3 class="text-2xl font-bold text-gray-800 mb-4">Complete Online Course Access</h3>
                        <p class="text-gray-600 mb-6 flex-grow">Perfect for learners moving beyond the basics, with a focus on real-life conversations and increasing complexity.</p>
                        <ul class="space-y-3 text-gray-700">
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Advanced beginner grammar & rich vocabulary</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Longer reading & listening passages</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Built-in checkpoints, worksheets & mini-tests</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Full A2-level test to assess your readiness for B1</li>
                        </ul>
                    </div>
                    <!-- All Aspects Card -->
                    <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 flex flex-col">
                        <div class="flex-shrink-0"><i class="fas fa-layer-group text-4xl text-blue-600 mb-4"></i></div>
                        <h3 class="text-2xl font-bold text-gray-800 mb-4">All Aspects Covered for Real Progress</h3>
                        <p class="text-gray-600 mb-6 flex-grow">This isn't just grammar revision — it’s full-skill development to help you use the language confidently.</p>
                        <ul class="space-y-3 text-gray-700">
                           <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Step-by-Step Grammar & Pronunciation</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Extended Reading & Listening Topics</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Speaking Prompts for Real-Life Scenarios</li>
                            <li class="flex items-center"><i class="fas fa-star text-yellow-500 mr-3"></i>Writing Practice, Worksheets, Tools & Tests</li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- Roadmap Section -->
        <section class="py-16 md:py-20 full-bleed-section-ghl">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                     <h2 class="text-3xl font-bold text-gray-900">A Clear Roadmap to Follow</h2>
                     <p class="mt-4 text-lg text-gray-600">Every unit is designed to build naturally on the last — no confusion, no overwhelm.</p>
                </div>

                <div class="relative">
                    <!-- The vertical line -->
                    <div class="absolute left-4 top-0 h-full w-0.5 bg-blue-200" aria-hidden="true"></div>

                    <!-- Timeline items -->
                    <div class="space-y-12">
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-play text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Unit 0: Structure Your Study Plan</h4>
                            <p class="text-gray-600">Begin with a clear plan on how to approach your A2 learning.</p>
                        </div>
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-book-open text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Units 1-6: Core A2 Syllabus</h4>
                            <p class="text-gray-600">Complete the entire A2 curriculum, including applied practice.</p>
                        </div>
                        <div class="relative pl-12">
                            <div class="absolute left-0 top-1.5 flex h-8 w-8 items-center justify-center rounded-full bg-blue-600"><i class="fas fa-graduation-cap text-white text-sm"></i></div>
                            <h4 class="font-bold text-lg text-gray-900">Final Test & Assessment</h4>
                            <p class="text-gray-600">Finish with a final A2 test to evaluate your readiness for the next level (B1).</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Access Duration & Final CTA -->
        <section class="py-16 md:py-20 bg-gray-800 text-white full-bleed-section-ghl" id="signup">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
                <div class="bg-gray-900/50 p-8 rounded-2xl mb-12 border border-gray-700">
                    <div class="flex justify-center items-center gap-4 mb-4">
                        <i class="fas fa-calendar-alt text-3xl text-blue-400"></i>
                        <h3 class="text-2xl font-bold">Instant Access for 4 Months</h3>
                    </div>
                    <p class="text-gray-300">You get 4 months of full course access. Learn when it works best for you, repeat lessons as needed, and track your progress without pressure.</p>
                </div>

                <h2 class="text-3xl font-bold mb-4">You’ve already started your French journey. Now let’s build on it.</h2>
                <p class="text-lg text-gray-300 mb-8">Learn independently. Speak with confidence. Let’s get going!</p>
                <a href="https://link.fastpaydirect.com/payment-link/684971d397daa447de9fc3fd" target="_blank" rel="noopener noreferrer" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-10 py-4 rounded-lg shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all duration-300 text-lg">
                    Enroll Now
                </a>
                <p class="text-sm text-gray-400 mt-6">Taught in English. Some content may not be translated.</p>
            </div>
        </section>


<!-- FAQs Section -->
<section class="py-16 md:py-20 full-bleed-section-ghl">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">Frequently Asked Questions</h2>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Before Joining</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Do I need to complete A1 before joining A2 Self-Study?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes — and if you’ve completed A1 or already know the basics, you’re ready to dive into A2.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">How long will it take to complete A2 Self-Study?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">With just 2–3 hours daily, you can finish in 1.5 to 2.5 months. Many students move to B1 within the same season they start A2.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What’s included in A2 Self-Study?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">You’ll get a full, structured learning path with step-by-step grammar lessons, real-world vocabulary, listening activities, reading passages, speaking assignments, and writing tasks — so you can progress without confusion.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What kind of support is available if I’m stuck?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">You’re never alone —you can upgrade to Intensive and join live sessions immediately.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Can I upgrade to A2 Intensive after starting Self-Study?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Absolutely — and most students who want faster speaking improvement choose this path. You just pay the balance fee and instantly get access to 4 weekly live sessions.</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">What does the A2 test include?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">A complete skills check — grammar, listening, reading, and an extensive list of speaking assignments to ensure you’re fully ready for B1.</p>
                    </div>
                </div>

            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-2xl font-semibold text-gray-800 mb-6 border-b-2 border-blue-100 pb-3">Promotions or Offers</h3>
            <div class="space-y-1">

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Do I get a discount on referring a friend?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Yes! For every friend you refer, you’ll receive $35 off, and your friend receives $35 off as well!</p>
                    </div>
                </div>

                <div class="border-b border-gray-200">
                    <button class="faq-toggle w-full text-left py-5 flex justify-between items-center hover:bg-gray-50 transition-colors duration-200">
                        <span class="text-lg font-medium text-gray-800">Is there a Combo Discount?</span>
                        <i class="fas fa-chevron-down text-blue-600 transform transition-transform duration-300"></i>
                    </button>
                    <div class="faq-answer">
                        <p class="text-gray-600 leading-relaxed pt-2 pb-4">Absolutely. We offer special combo pricing when you enroll in multiple programs together. For details, message on WhatsApp at 514-726-5114 directly.</p>
                    </div>
                </div>

            </div>
        </div>

    </div>
</section>
<!-- End of FAQs Section -->
<!-- Testimonial Widget -->
        <section class="py-16 md:py-20 bg-gray-50 full-bleed-section-ghl">
            <div class="max-w-[1170px] mx-auto px-4 sm:px-6 lg:px-8">
                <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">What Our Students Say</h2>

                <!-- Reputation Hub Widget Code -->
                <script type='text/javascript' src='https://reputationhub.site/reputation/assets/review-widget.js' is:inline></script>
                <iframe class='lc_reviews_widget' src='https://reputationhub.site/reputation/widgets/review_widget/cmjlzerv4DUDyZFj6PYO' frameborder='0' scrolling='no' style='min-width: 100%; width: 100%;'></iframe>
                <!-- End of Widget Code -->

            </div>
        </section>
    </main>

  <style is:global>
/* Styles for FAQ Accordion */
        .faq-answer {
            transition: max-height 0.5s ease-in-out, padding 0.5s ease-in-out;
            max-height: 0;
            overflow: hidden;
            padding-top: 0;
            padding-bottom: 0;
        }

        .faq-answer.open {
            max-height: 500px; /* Adjust based on content length */
            padding-top: 0.5rem;
            padding-bottom: 1rem;
        }

        .faq-toggle .fa-chevron-down {
            transition: transform 0.3s ease-in-out;
        }

        .faq-toggle.open .fa-chevron-down {
            transform: rotate(180deg);
        }
  </style>
</Layout>
