  <script slot="scripts" is:inline>
    // Sequential unlock staircase — preserves original button text ("Learn More")
    (function () {
      const STORAGE_KEY = 'frenchify-home-programs-unlocked';
      const staircase = document.querySelector('[data-staircase="home-programs"]');
      if (!staircase) return;

      const total = parseInt(staircase.dataset.total || '4', 10);
      const cards = Array.from(staircase.querySelectorAll('.path-card'));
      const arrows = Array.from(staircase.querySelectorAll('.path-arrow'));

      function getUnlocked() {
        try {
          const raw = parseInt(localStorage.getItem(STORAGE_KEY) || '1', 10);
          if (isNaN(raw) || raw < 1) return 1;
          if (raw > total) return total;
          return raw;
        } catch (e) { return 1; }
      }

      function setCardState(card, state) {
        card.classList.remove('path-card-active', 'path-card-locked', 'path-card-complete', 'path-card-dim');
        card.classList.add('path-card-' + state);
        if (state === 'locked') card.classList.add('path-card-dim');

        const badge = card.querySelector('.step-badge');
        if (badge) {
          badge.classList.remove('step-badge-active', 'step-badge-locked', 'step-badge-complete');
          badge.classList.add('step-badge-' + state);
        }

        const pill = card.querySelector('.status-pill');
        if (pill) {
          pill.classList.remove('status-pill-active', 'status-pill-locked', 'status-pill-complete');
          pill.classList.add('status-pill-' + state);
          if (state === 'active')       pill.innerHTML = '<span class="status-dot"></span> ACTIVE';
          else if (state === 'complete') pill.innerHTML = '<i class="fas fa-check text-[9px]"></i> COMPLETED';
          else                           pill.innerHTML = '<i class="fas fa-lock text-[9px]"></i> LOCKED';
        }

        const btn = card.querySelector('.path-action');
        if (btn) {
          btn.classList.remove('path-action-active', 'path-action-locked', 'path-action-complete');
          btn.classList.add('path-action-' + state);
          btn.disabled = (state === 'locked');
          // Swap leading icon only — never touch the "Learn More" label
          const leadingIcon = btn.querySelector('i:first-child');
          if (leadingIcon) {
            leadingIcon.className = state === 'locked'
              ? 'fas fa-lock text-xs'
              : (state === 'complete' ? 'fas fa-check-circle text-xs' : 'fas fa-arrow-right text-xs');
            // hide the trailing arrow on non-active states to reduce visual noise
          }
          const trailing = btn.querySelector('i:last-child');
          if (trailing && trailing !== leadingIcon) {
            trailing.style.display = state === 'active' ? '' : 'none';
          }
        }
      }

      function setArrowState(arrow, unlocked) {
        const pair = (arrow.dataset.arrow || '').split('-');
        const from = parseInt(pair[0], 10);
        arrow.classList.remove('path-arrow-active', 'path-arrow-dim');
        // Arrow is "hot" only between the card being completed and the one just unlocked
        if (from < unlocked) arrow.classList.add('path-arrow-active');
        else                 arrow.classList.add('path-arrow-dim');
      }

      function render() {
        const unlocked = getUnlocked();
        cards.forEach((card) => {
          const step = parseInt(card.dataset.step || '0', 10);
          if (step < unlocked)      setCardState(card, 'complete');
          else if (step === unlocked) setCardState(card, 'active');
          else                         setCardState(card, 'locked');
        });
        arrows.forEach((arrow) => setArrowState(arrow, unlocked));
      }

      function onActiveClick(e) {
        const btn = e.target.closest('.path-action');
        if (!btn) return;
        const card = btn.closest('.path-card');
        if (!card || !card.classList.contains('path-card-active')) return;
        e.preventDefault();
        const step = parseInt(card.dataset.step || '0', 10);
        const href = card.dataset.href || btn.getAttribute('href');

        // Advance unlocked level
        const next = Math.min(step + 1, total);
        try { localStorage.setItem(STORAGE_KEY, String(next)); } catch (e2) {}

        render();

        if (href) setTimeout(() => { window.location.href = href; }, 600);
      }

      staircase.addEventListener('click', onActiveClick);

      const resetBtn = document.querySelector('[data-staircase-reset="home-programs"]');
      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
          render();
        });
      }

      render();
    })();

    // FAQ functionality
    document.querySelectorAll('.faq-question').forEach(question => {
      question.addEventListener('click', function () {
        const answer = this.nextElementSibling;
        const icon = this.querySelector('i');

        document.querySelectorAll('.faq-question').forEach(q => {
          if (q !== this) {
            q.nextElementSibling.classList.remove('max-h-screen', 'py-4');
            q.nextElementSibling.classList.add('max-h-0');
            q.querySelector('i').classList.remove('fa-minus');
            q.querySelector('i').classList.add('fa-plus');
          }
        });

        if (answer.classList.contains('max-h-0')) {
          answer.classList.remove('max-h-0');
          answer.classList.add('max-h-screen', 'py-4');
          icon.classList.remove('fa-plus');
          icon.classList.add('fa-minus');
        } else {
          answer.classList.remove('max-h-screen', 'py-4');
          answer.classList.add('max-h-0');
          icon.classList.remove('fa-minus');
          icon.classList.add('fa-plus');
        }
      });
    });
  </script>
</Layout>
